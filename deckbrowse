#!/usr/bin/env python3
"""deckbrowse — Universal terminal browser for DeckDroid"""
import sys
import os
import subprocess
import shutil
import json
import pathlib
import urllib.parse
import re

# ── Arch + capability detection ──────────────────────────
try:
    result = subprocess.run(["uname", "-m"], capture_output=True, text=True, timeout=5)
    ARCH = result.stdout.strip()
except Exception:
    ARCH = "unknown"

CAPABLE_ARCHES = ("aarch64", "x86_64")
IS_CAPABLE = ARCH in CAPABLE_ARCHES

# ── Colors ────────────────────────────────────────
BOLD   = "\033[1m"
GREEN  = "\033[0;32m"
CYAN   = "\033[0;36m"
YELLOW = "\033[1;33m"
DIM    = "\033[2m"
RED    = "\033[0;31m"
RESET  = "\033[0m"

HOME = pathlib.Path.home()
DDROID = HOME / ".deckdroid"
BROWSE_W3M = DDROID / "browse.w3m"

def detect_browser():
    """Detect available terminal browsers"""
    browsers = []
    for b in ["w3m", "lynx", "browsh"]:
        if shutil.which(b):
            browsers.append(b)
    return browsers

def setup_w3m():
    """Setup w3m with XSS injection fix"""
    if BROWSE_W3M.exists():
        return
    
    config = """# DeckDroid w3m configuration
# XSS injection fix - restrict JavaScript
set display_link_number 1
set show_lnum 1
set accept_cookie 0
set use_cookie 0
"""
    BROWSE_W3M.write_text(config)

def search_web(query):
    """Search the web using default search engine"""
    # Use Google search
    url = f"https://www.google.com/search?q={urllib.parse.quote(query)}"
    return url

def cmd_open(args):
    """Open a URL or search query"""
    if not args:
        print(f"{BOLD}Usage: deckbrowse [URL|search query]{RESET}")
        print(f"\nExamples:")
        print(f"  deckbrowse github")
        print(f"  deckbrowse https://example.com")
        print(f"  deckbrowse search termux android")
        return
    
    input_str = " ".join(args)
    
    # Check if it's a URL
    if re.match(r'^https?://', input_str):
        url = input_str
    else:
        # Check for common shortcuts
        shortcuts = {
            "github": "https://github.com",
            "google": "https://www.google.com",
            "ddg": "https://duckduckgo.com",
            "yt": "https://www.youtube.com",
        }
        if input_str.lower() in shortcuts:
            url = shortcuts[input_str.lower()]
        else:
            url = search_web(input_str)
    
    print(f"\n{BOLD}deckbrowse — Terminal Browser{RESET}")
    print(f"{DIM}Opening: {url}{RESET}\n")
    
    browsers = detect_browser()
    if not browsers:
        print(f"{RED}No terminal browser found!{RESET}")
        print(f"Install one of: w3m, lynx, browsh")
        return
    
    setup_w3m()
    
    # Prefer w3m
    if "w3m" in browsers:
        cmd = ["w3m", "-config", str(BROWSE_W3M), url]
    elif "lynx" in browsers:
        cmd = ["lynx", url]
    else:
        cmd = [browsers[0], url]
    
    try:
        subprocess.run(cmd)
    except KeyboardInterrupt:
        print(f"\n{YELLOW}Browser closed.{RESET}")
    except Exception as e:
        print(f"{RED}Error: {e}{RESET}")

def cmd_list(args):
    """List available browsers"""
    print(f"\n{BOLD}deckbrowse — Available Browsers{RESET}\n")
    browsers = detect_browser()
    if not browsers:
        print(f"{YELLOW}No terminal browsers installed.{RESET}")
        print(f"\nInstall one of:")
        print(f"  pkg install w3m")
        print(f"  pkg install lynx")
        print(f"  pkg install browsh")
    else:
        print(f"{GREEN}Available browsers:{RESET}")
        for b in browsers:
            print(f"  {CYAN}● {b}{RESET}")
    print()

CMDS = {"open": cmd_open, "list": cmd_list}

if __name__ == "__main__":
    args = sys.argv[1:]
    if not args or (args[0] not in CMDS and args[0] not in ["search", "open"]):
        print(f"{BOLD}deckbrowse — Terminal Browser{RESET}")
        print(f"\nUsage: deckbrowse <command> [args]")
        print(f"\nCommands:")
        print(f"  {CYAN}open{RESET} <URL|query>  Open URL or search")
        print(f"  {CYAN}list{RESET}              List available browsers")
        print(f"\nShorthand:")
        print(f"  deckbrowse github        → opens GitHub")
        print(f"  deckbrowse search termux → searches for 'termux'")
        sys.exit(1)
    
    if args[0] == "search":
        cmd_open(args[1:])
    else:
        CMDS[args[0]](args[1:])
