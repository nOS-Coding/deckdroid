#!/usr/bin/env python3
"""deckbrowse — Universal terminal browser for DeckDroid"""
import sys, os, subprocess, shutil, json, pathlib, urllib.parse, re

# ── Arch + capability detection ──────────────────────────
ARCH = subprocess.run(["uname", "-m"], capture_output=True, text=True).stdout.strip()
CAPABLE_ARCHES = ("aarch64", "x86_64")
IS_CAPABLE = ARCH in CAPABLE_ARCHES

# ── Colors ────────────────────────────────────────
BOLD   = "\033[1m"
GREEN  = "\033[0;32m"
CYAN   = "\033[0;36m"
YELLOW = "\033[1;33m"
DIM    = "\033[2m"
RESET  = "\033[0m"
CLEAR  = "\033[2J\033[H"

# ── UA string — mobile Chrome, works on Google ───────────
UA = "Mozilla/5.0 (Linux; Android 10; K) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Mobile Safari/537.36"

# ── Config ─────────────────────────────────────────
DDROID   = pathlib.Path.home() / ".deckdroid"
CFG     = DDROID / "config.json"
HISTORY = DDROID / "browser_history.txt"
BOOKMARKS = DDROID / "bookmarks.txt"

def load_cfg():
    try:
        return json.loads(CFG.read_text())
    except Exception:
        return {}

# ── Engine detection — pick best available ─────────────────
def detect_engine():
    cfg = load_cfg()
    preferred = cfg.get("browser", {}).get("engine", "auto")
    
    if preferred != "auto" and shutil.which(preferred):
        return preferred
    
    if IS_CAPABLE and shutil.which("browsh"):
        return "browsh"
    if IS_CAPABLE and shutil.which("browsh"):
        return "browsh"
    if shutil.which("w3m"):
        return "w3m"
    if shutil.which("lynx"):
        return "lynx"
    if shutil.which("elinks"):
        return "elinks"
    return None

# ── Browser launch functions ──────────────────────────────
def launch_w3m(url):
    w3m_cfg = pathlib.Path.home() / ".w3m"
    w3m_cfg.mkdir(exist_ok=True)
    
    config_file = w3m_cfg / "config"
    if not config_file.exists() or "DeckDroid" not in config_file.read_text(errors="replace"):
        config_file.write_text(
            f"# DeckDroid w3m config\n"
            f"default_url https://www.google.com/search?q=\n"
            f"user_agent {UA}\n"
            f"color 1\n"
            f"display_image 1\n"
            f"confirm_qq 0\n"
            f"use_mouse 1\n"
            f"display_charset UTF-8\n"
            f"document_charset UTF-8\n"
            f"ssl_verify_server 0\n"
        )
    
    os.execvp("w3m", ["w3m", "-o", f"user_agent={UA}", url])

def launch_lynx(url):
    os.execvp("lynx", ["lynx", f"-useragent={UA}", "-accept_all_cookies", "-display_charset=utf-8", url])

def launch_elinks(url):
    os.execvp("elinks", ["elinks", url])

def launch_browsh(url):
    os.execvp("browsh", ["browsh", "--startup-url", url])

def launch_browsh(url):
    os.execvp("browsh", ["browsh", url])

LAUNCHERS = {
    "w3m":     launch_w3m,
    "lynx":    launch_lynx,
    "elinks":  launch_elinks,
    "browsh":  launch_browsh,
    "browsh": launch_browsh,
}

# ── URL handling ───────────────────────────────────────
def resolve_input(raw):
    raw = raw.strip()
    if not raw:
        return "https://www.google.com"
    
    has_scheme  = raw.startswith(("http://", "https://", "ftp://"))
    looks_like_domain = re.match(r'^[a-zA-Z0-9\-]+\.[a-zA-Z]{2,}(/.*)?$', raw) and " " not in raw
    
    if has_scheme or looks_like_domain:
        if not has_scheme:
            raw = "https://" + raw
        return raw
    
    query = urllib.parse.quote_plus(raw)
    return f"https://www.google.com/search?q={query}"

# ── History ──────────────────────────────────────────
def add_history(entry):
    try:
        with open(HISTORY, "a") as f:
            f.write(entry.strip() + "\n")
    except Exception:
        pass

def load_history(n=10):
    try:
        lines = HISTORY.read_text().strip().splitlines()
        seen = set()
        result = []
        for line in reversed(lines):
            if line not in seen:
                seen.add(line)
                result.append(line)
            if len(result) >= n:
                break
        return list(reversed(result))
    except Exception:
        return []

# ── Bookmarks ───────────────────────────────────────
def load_bookmarks():
    try:
        lines = BOOKMARKS.read_text().strip().splitlines()
        return [l for l in lines if l.strip() and not l.startswith("#")]
    except Exception:
        return []

def add_bookmark(url, title=""):
    try:
        entry = f"{url}" + (f"  # {title}" if title else "")
        with open(BOOKMARKS, "a") as f:
            f.write(entry + "\n")
        print(f"{GREEN}✓{RESET} Bookmarked: {url}")
    except Exception as e:
        print(f"Could not save bookmark: {e}")

# ── Interactive TUI launcher ──────────────────────────
def tui_launcher(engine):
    history   = load_history()
    bookmarks = load_bookmarks()
    
    cols = int(subprocess.run(["tput", "cols"], capture_output=True, text=True).stdout.strip() or 80)
    bar  = "─" * min(cols, 60)
    
    print(CLEAR, end="")
    print(f"""
 {BOLD}{CYAN}  deckbrowse{RESET} {DIM}— DeckDroid browser{RESET}
   {bar}
   {DIM}engine: {engine}   arch: {ARCH}{RESET}
""")
    
    if bookmarks:
        print(f"  {BOLD}Bookmarks{RESET}")
        for i, bm in enumerate(bookmarks[:6], 1):
            url   = bm.split("#")[0].strip()
            label = bm.split("#")[1].strip() if "#" in bm else url[:40]
            print(f"  {CYAN}[{i}]{RESET} {label}")
        print()
    
    if history:
        print(f"  {BOLD}Recent{RESET}")
        for i, h in enumerate(history[-5:], 1):
            print(f"  {DIM}{i}.{RESET} {h[:55]}")
        print()
    
    print(f"  {bar}")
    print(f"  {DIM}Type a URL or search query. Press Enter to go. Ctrl+C to exit.{RESET}")
    print()
    
    try:
        raw = input(f"  {BOLD}{GREEN}❯{RESET} ").strip()
    except (KeyboardInterrupt, EOFError):
        print(f"\n{DIM}bye.{RESET}\n")
        sys.exit(0)
    
    if raw.isdigit() and bookmarks:
        idx = int(raw) - 1
        if 0 <= idx < len(bookmarks):
            raw = bookmarks[idx].split("#")[0].strip()
    
    return raw

# ── Main ─────────────────────────────────────────────
def main():
    args = sys.argv[1:]
    
    if args and args[0] == "bookmarks":
        bms = load_bookmarks()
        if not bms:
            print("No bookmarks yet. Browse somewhere and use: deckbrowse --bookmark <url>")
        else:
            print(f"\n{BOLD}deckbrowse — Bookmarks{RESET}")
            for bm in bms:
                print(f"  {CYAN}•{RESET} {bm}")
        return
    
    if args and args[0] == "history":
        hist = load_history(20)
        if not hist:
            print("No history yet.")
        else:
            print(f"\n{BOLD}deckbrowse — History{RESET}")
            for h in hist:
                print(f"  {DIM}·{RESET} {h}")
        return
    
    if args and args[0] in ("--bookmark", "-b") and len(args) >= 2:
        title = " ".join(args[2:]) if len(args) > 2 else ""
        add_bookmark(args[1], title)
        return
    
    if args and args[0] in ("--engine", "-e"):
        cfg = load_cfg()
        if len(args) >= 2:
            cfg.setdefault("browser", {})["engine"] = args[1]
            CFG.write_text(json.dumps(cfg, indent=2))
            print(f"{GREEN}✓{RESET} Engine set to: {args[1]}")
        else:
            print(f"Current engine: {cfg.get('browser',{}).get('engine','auto')}")
        return
    
    if args and args[0] in ("--help", "-h"):
        print(f"""
 {BOLD}deckbrowse{RESET} — Universal terminal browser for DeckDroid
 
 {BOLD}Usage:{RESET}
   deckbrowse                      Interactive launcher (home screen)
   deckbrowse <url>                Open URL directly
   deckbrowse <search query>       Search Google directly
   deckbrowse google               Open google.com
   deckbrowse youtube.com          Open YouTube (text mode)
 
 {BOLD}Sub-commands:{RESET}
   deckbrowse bookmarks            List bookmarks
   deckbrowse history              Show recent history
   deckbrowse --bookmark <url> [title]  Save a bookmark
   deckbrowse --engine <name>      Set preferred engine (auto/w3m/lynx/browsh)
 
 {BOLD}Engines available on this device ({ARCH}):{RESET}
""")
        for e in ["browsh", "browsh", "w3m", "lynx", "elinks"]:
            found = shutil.which(e)
            status = f"{GREEN}✓ available{RESET}" if found else f"{DIM}✗ not installed{RESET}"
            print(f"  {e:<10} {status}")
        print()
        return
    
    engine = detect_engine()
    if not engine:
        print(f"{YELLOW}No browser engine found.{RESET}")
        print("Install one: pkg install w3m   or   pkg install lynx")
        sys.exit(1)
    
    if args:
        raw = " ".join(args)
        if raw.lower() == "google":
            raw = "google.com"
        elif raw.lower() in ("home", ""):
            raw = "https://www.google.com"
    else:
        try:
            raw = tui_launcher(engine)
        except (EOFError, OSError):
            raw = "https://www.google.com"
    
    url = resolve_input(raw)
    add_history(raw if raw.startswith("http") else url)
    
    print(f"\n  {DIM}opening {url[:70]} via {engine}{RESET}\n")
    
    launcher = LAUNCHERS.get(engine)
    if launcher:
        launcher(url)
    else:
        os.execvp(engine, [engine, url])

if __name__ == "__main__":
    main()
