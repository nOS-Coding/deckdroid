#!/usr/bin/env python3
"""deckupdate — Check and auto-update DeckDroid"""
import sys
import json
import pathlib
import subprocess
import os
import re

HOME = pathlib.Path.home()
DDROID = HOME / ".deckdroid"
CFG = DDROID / "config.json"
GREEN = "\033[0;32m"
YELLOW = "\033[1;33m"
CYAN = "\033[0;36m"
RESET = "\033[0m"
BOLD = "\033[1m"
RED = "\033[0;31m"

LATEST_URL = "https://api.github.com/repos/nOS-Coding/deckdroid/releases/latest"
INSTALL_URL = "https://nos-coding.github.io/deckdroid/install.sh"

def load_cfg():
    if CFG.exists():
        return json.loads(CFG.read_text())
    return {"auto_update": False, "version": "0.0.0"}

def save_cfg(cfg):
    CFG.write_text(json.dumps(cfg, indent=2))

def get_current_version():
    """Get current version from config, fallback to repo version"""
    cfg = load_cfg()
    version = cfg.get("version", "")
    
    # If version is empty or default, try to get from repo
    if not version or version in ["0.0.0", "0.1.0", "unknown"]:
        # Try to get version from GitHub repo (default branch)
        try:
            result = subprocess.run(
                ["curl", "-sL", "--max-time", "10",
                 "-H", "User-Agent: DeckDroid",
                 "https://raw.githubusercontent.com/nOS-Coding/deckdroid/main/config.template.json"],
                capture_output=True, text=True, timeout=15
            )
            if result.returncode == 0 and result.stdout:
                data = json.loads(result.stdout)
                return data.get("version", "0.0.0")
        except Exception:
            pass
    
    return version or "0.0.0"

def get_latest_version():
    """Get latest version using curl - check tags if no release"""
    try:
        # Try releases first
        result = subprocess.run(
            ["curl", "-sL", "--max-time", "10",
             "-H", "User-Agent: DeckDroid",
             "-H", "Accept: application/json",
             LATEST_URL],
            capture_output=True, text=True, timeout=15
        )
        if result.returncode == 0 and result.stdout:
            data = json.loads(result.stdout)
            tag = data.get("tag_name", "")
            # Only use if it's a proper release (not draft/prerelease)
            if tag and not data.get("draft", False) and not data.get("prerelease", False):
                return tag.lstrip("v")
        
        # Fallback: get latest tag
        tags_url = "https://api.github.com/repos/nOS-Coding/deckdroid/tags"
        result = subprocess.run(
            ["curl", "-sL", "--max-time", "10",
             "-H", "User-Agent: DeckDroid",
             tags_url],
            capture_output=True, text=True, timeout=15
        )
        if result.returncode == 0 and result.stdout:
            tags = json.loads(result.stdout)
            if tags:
                return tags[0].get("name", "v0.0.0").lstrip("v")
        
        return None
    except Exception as e:
        return None

def parse_version(v):
    """Parse version string to tuple"""
    try:
        # Remove leading 'v' if present
        v = v.lstrip("v")
        return tuple(int(x) for x in v.split("."))
    except:
        return (0,0,0)

def cmd_check(args):
    current = get_current_version()
    print(f"\n{BOLD}DeckDroid — Update Checker{RESET}\n")
    print(f"  Current version: {CYAN}{current}{RESET}")
    
    latest = get_latest_version()
    if latest is None:
        print(f"\n  {YELLOW}⚠ Could not check for updates (network error){RESET}")
        print(f"  {YELLOW}Check your internet connection{RESET}")
        return
    
    print(f"  Latest version:  {CYAN}{latest}{RESET}")
    
    cur_tuple = parse_version(current)
    lat_tuple = parse_version(latest)
    
    if lat_tuple > cur_tuple:
        print(f"\n  {YELLOW}⚠ Update available!{RESET}")
        print(f"  Run: deckupdate upgrade")
    else:
        print(f"\n  {GREEN}✓ Up to date{RESET}")
    print()

def cmd_status(args):
    cfg = load_cfg()
    auto = cfg.get("auto_update", False)
    current = get_current_version()
    latest = get_latest_version()
    
    print(f"\n{BOLD}DeckDroid — Update Status{RESET}\n")
    print(f"  Current version: {CYAN}{current}{RESET}")
    print(f"  Latest version:  {CYAN}{latest if latest else 'unknown'}{RESET}")
    status = f"{GREEN}enabled{RESET}" if auto else f"{YELLOW}disabled{RESET}"
    print(f"  Auto-update:      {status}")
    print()

def cmd_auto(args):
    cfg = load_cfg()
    
    if not args:
        auto = cfg.get("auto_update", False)
        status = f"{GREEN}enabled{RESET}" if auto else f"{YELLOW}disabled{RESET}"
        print(f"\nAuto-update is {status}")
        return
    
    if args[0] == "on":
        cfg["auto_update"] = True
        save_cfg(cfg)
        print(f"\n{GREEN}✓ Auto-update enabled{RESET}")
        print(f"  DeckDroid will check and update on each shell start.")
    elif args[0] == "off":
        cfg["auto_update"] = False
        save_cfg(cfg)
        print(f"\n{YELLOW}◦ Auto-update disabled{RESET}")
    elif args[0] == "status":
        auto = cfg.get("auto_update", False)
        print(f"\nAuto-update: {'enabled' if auto else 'disabled'}")
    else:
        print(f"Usage: deckupdate auto [on|off|status]")

def cmd_upgrade(args):
    print(f"\n{BOLD}Upgrading DeckDroid...{RESET}\n")
    print(f"  Fetching installer from {INSTALL_URL}...")
    
    try:
        result = subprocess.run(
            ["curl", "-sL", "--max-time", "30", INSTALL_URL],
            capture_output=True, text=True, timeout=35
        )
        if result.returncode != 0:
            print(f"{RED}✗ Failed to download installer{RESET}")
            return
        
        installer_path = DDROID / "install.sh"
        with open(installer_path, "w") as f:
            f.write(result.stdout)
        os.chmod(installer_path, 0o755)
        
        print(f"  Running installer...")
        subprocess.run(["bash", str(installer_path)])
        
    except Exception as e:
        print(f"{RED}✗ Upgrade failed: {e}{RESET}")

def cmd_info(args):
    current = get_current_version()
    cfg = load_cfg()
    print(f"\n{BOLD}DeckDroid — Info{RESET}\n")
    print(f"  Version:   {current}")
    print(f"  Home:      {DDROID}")
    print(f"  Auto-upd:  {cfg.get('auto_update', False)}")
    if CFG.exists():
        cfg = json.loads(CFG.read_text())
        print(f"  Hostname:  {cfg.get('hostname', 'N/A')}")
        print(f"  Theme:     {cfg.get('theme', {}).get('name', 'N/A')}")
        print(f"  Profiles:  {', '.join(cfg.get('profiles', [])) or 'none'}")
    print()

CMDS = {"check": cmd_check, "status": cmd_status, "auto": cmd_auto, "upgrade": cmd_upgrade, "info": cmd_info}

if __name__ == "__main__":
    args = sys.argv[1:]
    if not args or args[0] not in CMDS:
        print(f"{BOLD}deckupdate — Update Checker{RESET}")
        print(f"Usage: deckupdate <command>")
        print(f"\nCommands:")
        print(f"  {CYAN}check{RESET}    Check for new version")
        print(f"  {CYAN}upgrade{RESET}  Upgrade to latest version")
        print(f"  {CYAN}auto{RESET}      Toggle/see auto-update status")
        print(f"  {CYAN}status{RESET}    Show detailed update status")
        print(f"  {CYAN}info{RESET}     Show current installation info")
        sys.exit(1)
    CMDS[args[0]](args[1:])
