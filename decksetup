#!/usr/bin/env python3
"""decksetup — First-run setup wizard for TermuxDeck OS"""
import sys, json, pathlib, subprocess, os

HOME = pathlib.Path.home()
TDECK = HOME / ".termuxdeck"
CFG = TDECK / "config.json"
GREEN = "\033[0;32m"; YELLOW = "\033[1;33m"; CYAN = "\033[0;36m"; RESET = "\033[0m"; BOLD = "\033[1m"; DIM = "\033[2m"

PROFILES = ["hacker", "developer", "writer", "crypto", "radio", "hamradio", "iot"]
VISUAL_THEMES = ["cyberpunk", "ghost", "blood", "matrix", "nord", "dracula", "monokai", "ocean"]

def load_cfg():
    if CFG.exists():
        try:
            return json.loads(CFG.read_text())
        except:
            pass
    return {"version": "1.1.0", "profiles": [], "theme": {"name": "cyberpunk"}}

def save_cfg(cfg):
    CFG.write_text(json.dumps(cfg, indent=2))

def input_with_default(prompt, default):
    """Get input with a default value"""
    response = input(f"{prompt} [{default}]: ").strip()
    return response if response else default

def select_option(prompt, options, current=None):
    """Show numbered selection menu"""
    print(f"\n{BOLD}{prompt}{RESET}")
    for i, opt in enumerate(options, 1):
        marker = " ◉" if opt == current else " ○"
        print(f"  {CYAN}{i}.{RESET} {opt}{marker}")
    print(f"  {YELLOW}0.{RESET} Skip/None")
    
    while True:
        try:
            choice = input(f"\n{BOLD}Select:{RESET} ").strip()
            if choice == "0" or choice == "":
                return current if current else None
            idx = int(choice) - 1
            if 0 <= idx < len(options):
                return options[idx]
        except ValueError:
            pass
        print("Invalid choice. Try again.")

def cmd_run(args):
    """Run the setup wizard"""
    print(f"""
{BOLD}{CYAN}
╔══════════════════════════════════════════════════════╗
║     TermuxDeck OS — First-Run Setup Wizard          ║
╚══════════════════════════════════════════════════════╝{RESET}
{DIM}Let's configure your cyberdeck...{RESET}
""")
    
    cfg = load_cfg()
    
    # ─── Hostname ───
    print(f"\n{BOLD}── Hostname ───────────────────────────────────────────────{RESET}")
    current_host = cfg.get("hostname", "tdeck-" + format(hash(str(os.times())) % 10000, '04d'))
    hostname = input_with_default("Choose a device name", current_host)
    cfg["hostname"] = hostname
    
    # ─── Profile Selection ───
    print(f"\n{BOLD}── Profile ────────────────────────────────────────────────{RESET}")
    print(f"{DIM}Select your primary use case:{RESET}")
    profile = select_option("Profile", PROFILES, cfg.get("profiles", [None])[0] if cfg.get("profiles") else None)
    if profile:
        if "profiles" not in cfg:
            cfg["profiles"] = []
        if profile not in cfg["profiles"]:
            cfg["profiles"].append(profile)
        
        # Install profile packages
        print(f"\n{DIM}Installing {profile} profile packages...{RESET}")
        profile_pkgs = {
            "hacker": ["nmap", "tcpdump", "netcat-openbsd", "curl", "wget", "whois", "dnsutils"],
            "developer": ["git", "openssh", "python", "nodejs", "nano"],
            "writer": ["mdcat", "pandoc"],
            "crypto": ["gnupg", "openssl"],
            "radio": ["rtl-sdr", "sox", "multimon-ng"],
            "hamradio": ["gnupg"],
            "iot": ["python", "mosquitto-clients"],
        }
        
        for pkg in profile_pkgs.get(profile, []):
            print(f"  Installing {pkg}...", end=" ")
            try:
                subprocess.run(["pkg", "install", "-y", pkg], capture_output=True, timeout=60)
                print(f"{GREEN}OK{RESET}")
            except:
                print(f"{YELLOW}skipped{RESET}")
    
    # ─── Theme Selection ───
    print(f"\n{BOLD}── Theme ────────────────────────────────────────────────{RESET}")
    print(f"{DIM}Choose your visual style:{RESET}")
    theme = select_option("Theme", VISUAL_THEMES, cfg.get("theme", {}).get("name", "cyberpunk"))
    if theme:
        if "theme" not in cfg:
            cfg["theme"] = {}
        cfg["theme"]["name"] = theme
    
    # ─── Auto-update ───
    print(f"\n{BOLD}── Auto-Update ──────────────────────────────────────────{RESET}")
    print(f"{DIM}Would you like TermuxDeck to automatically update on shell start?{RESET}")
    print(f"  {CYAN}Y{RESET}es - Check and prompt for updates")
    print(f"  {CYAN}N{RESET}o  - Manual updates only")
    
    auto_update = input(f"\n{BOLD}Enable auto-update?{RESET} [Y/n]: ").strip().lower()
    cfg["auto_update"] = auto_update in ("", "y", "yes")
    
    # ─── Additional Packages ───
    print(f"\n{BOLD}── Additional Packages ────────────────────────────────────{RESET}")
    print(f"{DIM}Install common packages? (space-separated, Enter for none){RESET}")
    print(f"  Common: {CYAN}neofetch vim curl wget git openssh python nodejs w3m termux-api{RESET}")
    
    extra = input(f"\n{BOLD}Additional packages:{RESET} ").strip()
    if extra:
        print(f"\n{DIM}Installing additional packages...{RESET}")
        for pkg in extra.split():
            print(f"  {pkg}...", end=" ")
            try:
                subprocess.run(["pkg", "install", "-y", pkg], capture_output=True, timeout=60)
                print(f"{GREEN}OK{RESET}")
            except:
                print(f"{YELLOW}skipped{RESET}")
    
    # ─── Save Config ───
    save_cfg(cfg)
    
    print(f"""
{BOLD}{GREEN}
╔══════════════════════════════════════════════════════╗
║              Setup Complete!                         ║
╚══════════════════════════════════════════════════════╝{RESET}

Your TermuxDeck OS is configured:
  • Hostname:  {hostname}
  • Profile:  {profile if profile else 'base'}
  • Theme:    {theme}
  • Auto-upd: {'Yes' if cfg.get('auto_update') else 'No'}

Next steps:
  • Run 'zsh' to enter your cyberdeck
  • Run 'deckmenu' to browse tools
  • Run 'deckhelp' for documentation

{DIM}Type 'decksetup' anytime to reconfigure.{RESET}
""")

def cmd_status(args):
    """Show current setup status"""
    cfg = load_cfg()
    print(f"\n{BOLD}TermuxDeck OS — Setup Status{RESET}\n")
    print(f"  Hostname:    {cfg.get('hostname', 'N/A')}")
    print(f"  Theme:       {cfg.get('theme', {}).get('name', 'N/A')}")
    print(f"  Profiles:    {', '.join(cfg.get('profiles', [])) or 'none'}")
    print(f"  Auto-update: {'Yes' if cfg.get('auto_update') else 'No'}")
    print(f"\nRun 'decksetup' to reconfigure.")
    print()

CMDS = {"run": cmd_run, "status": cmd_status}

if __name__ == "__main__":
    args = sys.argv[1:]
    
    # Auto-run if no args
    if not args:
        cmd_run([])
    elif args[0] == "--help" or args[0] == "-h":
        print(f"{BOLD}decksetup — First-Run Setup Wizard{RESET}")
        print(f"Usage: decksetup")
        print(f"       decksetup status")
        print(f"\nRuns automatically on first boot to configure:")
        print(f"  • Hostname")
        print(f"  • Profile")
        print(f"  • Theme")
        print(f"  • Auto-update")
        print(f"  • Additional packages")
    elif args[0] in CMDS:
        CMDS[args[0]](args[1:])
    else:
        cmd_run([])