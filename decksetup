#!/usr/bin/env bash
# decksetup — First-run setup wizard for DeckDroid
# Usage: decksetup
set -eo pipefail

DDROID_HOME="${DDROID_HOME:-$HOME/.deckdroid}"
CFG="$DDROID_HOME/config.json"

R='\033[0;31m'; G='\033[0;32m'; Y='\033[1;33m'; CYAN='\033[0;36m'
B='\033[1m'; RESET='\033[0m'

echo -e "${B}${CYAN}"
echo "╔══════════════════════════════════════════╗"
echo "║     DeckDroid — Setup Wizard              ║"
echo "╚══════════════════════════════════════════╝${RESET}"
echo ""

# Hostname
echo -e "${B}1. Hostname Setup${RESET}"
echo -e "${DIM}Current: $(jq -r '.hostname // "droid"' "$CFG" 2>/dev/null)${RESET}"
read -r -p "Enter hostname [droid-XXXX]: " HOSTNAME
HOSTNAME=${HOSTNAME:-"droid-$(printf "%04x" $RANDOM)"}

if [ -f "$CFG" ]; then
    jq --arg hn "$HOSTNAME" '.hostname = $hn' "$CFG" > "$CFG.tmp" && mv "$CFG.tmp" "$CFG"
else
    mkdir -p "$DDROID_HOME"
    cat > "$CFG" <<EOF
{
  "version": "1.1.0",
  "hostname": "$HOSTNAME",
  "profiles": [],
  "theme": {"name": "cyberpunk", "type": "visual"}
}
EOF
fi
echo -e "${G}✓ Hostname set to: $HOSTNAME${RESET}\n"

# Profile
echo -e "${B}2. Profile Selection${RESET}"
echo -e "Available: ${CYAN}hacker${RESET}, ${CYAN}developer${RESET}, ${CYAN}writer${RESET}, ${CYAN}crypto${RESET}, ${CYAN}radio${RESET}, ${CYAN}iot${RESET}"
read -r -p "Select profile (or skip): " PROFILE

if [ -n "$PROFILE" ]; then
    echo -e "${Y}Installing profile: $PROFILE${RESET}"
    if command -v ddeckprof &>/dev/null; then
        ddeckprof set "$PROFILE"
    else
        echo -e "${Y}⚠ ddeckprof not found. Install profiles manually later.${RESET}"
    fi
fi

# Theme
echo -e "\n${B}3. Theme Selection${RESET}"
echo -e "Visual themes: ${CYAN}cyberpunk${RESET}, ${CYAN}ghost${RESET}, ${CYAN}blood${RESET}, ${CYAN}matrix${RESET}, ${CYAN}nord${RESET}, ${CYAN}dracula${RESET}, ${CYAN}monokai${RESET}, ${CYAN}ocean${RESET}"
read -r -p "Select theme [cyberpunk]: " THEME
THEME=${THEME:-cyberpunk}

if command -v decktheme &>/dev/null; then
    decktheme set "$THEME"
else
    echo -e "${Y}⚠ decktheme not found. Set theme manually later.${RESET}"
fi

# Auto-update
echo -e "\n${B}4. Auto-Update${RESET}"
read -r -p "Enable auto-update? (y/n) [n]: " AUTO
if [[ "$AUTO" =~ ^[yY]$ ]]; then
    if [ -f "$CFG" ]; then
        jq '.auto_update = true' "$CFG" > "$CFG.tmp" && mv "$CFG.tmp" "$CFG"
        echo -e "${G}✓ Auto-update enabled${RESET}"
    fi
else
    echo -e "${Y}◦ Auto-update disabled${RESET}"
fi

# Additional packages
echo -e "\n${B}5. Additional Packages${RESET}"
echo -e "${DIM}Recommended: nmap, tcpdump, git, python, nodejs${RESET}"
read -r -p "Install additional packages? (y/n) [n]: " PKGS
if [[ "$PKGS" =~ ^[yY]$ ]]; then
    echo -e "${Y}Installing packages...${RESET}"
    pkg install -y nmap tcpdump 2>/dev/null || true
fi

echo -e "\n${B}${G}✓ Setup complete!${RESET}"
echo -e "Run ${CYAN}zsh${RESET} to start your DeckDroid experience.\n"
