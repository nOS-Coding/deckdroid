#!/usr/bin/env bash
# decksetup — DeckDroid First-Run Setup Wizard
set -euo pipefail

DDROID_HOME="${DDROID_HOME:-$HOME/.deckdroid}"
CFG="$DDROID_HOME/config.json"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

echo -e "${BOLD}${CYAN}"
echo "╔═════════════════════════════════════════════╗"
echo "║       DeckDroid — First-Run Setup Wizard        ║"
echo "╚═════════════════════════════════════════════╝${RESET}"
echo ""

# ── Hostname ──────────────────────────────────────
echo -e "${BOLD}1. Hostname${RESET}"
echo -e "${DIM}   Enter a name for your device:${RESET}"
read -r -p "   Hostname: " HOSTNAME
HOSTNAME=${HOSTNAME:-"droid-$(printf "%04x" $RANDOM)"}

if command -v python3 &>/dev/null; then
  python3 -c "
import json
cfg = json.load(open('$CFG'))
cfg['hostname'] = '$HOSTNAME'
json.dump(cfg, open('$CFG', 'w'), indent=2)
"
  echo -e "${GREEN}✓ Hostname set to: $HOSTNAME${RESET}"
fi

# ── Profile ─────────────────────────────────────────
echo ""
echo -e "${BOLD}2. Profile${RESET}"
echo -e "${DIM}   Choose your mission profile:${RESET}"
echo -e "   ${CYAN}1${RESET}) hacker     — Security tools (nmap, tcpdump, etc.)"
echo -e "   ${CYAN}2${RESET}) developer  — Dev environment (git, python, nodejs)"
echo -e "   ${CYAN}3${RESET}) writer     — Writing tools (markdown, pandoc)"
echo -e "   ${CYAN}4${RESET}) crypto     — Encryption tools (GPG, openssl)"
echo -e "   ${CYAN}5${RESET}) radio      — SDR tools (RTL-SDR, radio)"
echo -e "   ${CYAN}6${RESET}) iot        — IoT tools (serial, MQTT)"
echo -e "   ${CYAN}0${RESET}) Skip"

read -r -p "   Choice: " PROFILE_CHOICE

case "$PROFILE_CHOICE" in
  1) PROFILE="hacker" ;;
  2) PROFILE="developer" ;;
  3) PROFILE="writer" ;;
  4) PROFILE="crypto" ;;
  5) PROFILE="radio" ;;
  6) PROFILE="iot" ;;
  *) echo -e "${YELLOW}Skipping profile selection.${RESET}"; PROFILE="" ;;
esac

if [ -n "$PROFILE" ]; then
  echo -e "${CYAN}Installing $PROFILE profile...${RESET}"
  if command -v ddeckprof &>/dev/null; then
    ddeckprof set "$PROFILE" 2>/dev/null || echo -e "${YELLOW}Profile install skipped (may not be available)${RESET}"
  fi
fi

# ── Theme ───────────────────────────────────────────
echo ""
echo -e "${BOLD}3. Theme${RESET}"
echo -e "${DIM}   Choose your visual theme:${RESET}"
echo -e "   ${CYAN}1${RESET}) cyberpunk — Green/cyan, matrix-style (default)"
echo -e "   ${CYAN}2${RESET}) ghost      — White/grey, minimal"
echo -e "   ${CYAN}3${RESET}) blood      — Deep red, aggressive"
echo -e "   ${CYAN}4${RESET}) nord       — Arctic blue"
echo -e "   ${CYAN}5${RESET}) ocean      — Deep blue"
echo -e "   ${CYAN}0${RESET}) Skip"

read -r -p "   Choice: " THEME_CHOICE

case "$THEME_CHOICE" in
  1) THEME="cyberpunk" ;;
  2) THEME="ghost" ;;
  3) THEME="blood" ;;
  4) THEME="nord" ;;
  5) THEME="ocean" ;;
  *) echo -e "${YELLOW}Skipping theme selection.${RESET}"; THEME="" ;;
esac

if [ -n "$THEME" ]; then
  if command -v decktheme &>/dev/null; then
    decktheme set "$THEME" 2>/dev/null || echo -e "${YELLOW}Theme set skipped${RESET}"
  fi
fi

# ── Auto-update ─────────────────────────────────────
echo ""
echo -e "${BOLD}4. Auto-Update${RESET}"
echo -e "${DIM}   Enable automatic update checks?${RESET}"
echo -e "   ${CYAN}1${RESET}) Yes — Check for updates on shell start"
echo -e "   ${CYAN}2${RESET}) No  — Manual updates only"

read -r -p "   Choice: " AUTO_CHOICE

if [ "$AUTO_CHOICE" = "1" ]; then
  if command -v deckupdate &>/dev/null; then
    deckupdate auto on 2>/dev/null || true
    echo -e "${GREEN}✓ Auto-update enabled${RESET}"
  fi
else
  echo -e "${YELLOW}Auto-update disabled.${RESET}"
fi

# ── Additional packages ────────────────────────────
echo ""
echo -e "${BOLD}5. Additional Packages${RESET}"
echo -e "${DIM}   Install some handy extras?${RESET}"
echo -e "   ${CYAN}1${RESET}) Yes — Install vim, htop, neofetch"
echo -e "   ${CYAN}2${RESET}) No  — Skip"

read -r -p "   Choice: " PKGS_CHOICE

if [ "$PKGS_CHOICE" = "1" ]; then
  echo -e "${CYAN}Installing extras...${RESET}"
  pkg install -y vim htop neofetch 2>/dev/null || echo -e "${YELLOW}Some packages may not be available${RESET}"
fi

# ── Finish ───────────────────────────────────────────
echo ""
echo -e "${BOLD}${GREEN}"
echo "╔═════════════════════════════════════════════╗"
echo "║       DeckDroid Setup Complete!               ║"
echo "╚═════════════════════════════════════════════╝${RESET}"
echo ""
echo -e "${CYAN}Run these commands:${RESET}"
echo -e "  ${BOLD}zsh${RESET}        — Start DeckDroid shell"
echo -e "  ${BOLD}deckmenu${RESET}    — Launch interactive menu"
echo -e "  ${BOLD}deckhelp${RESET}    — View help"
echo ""
