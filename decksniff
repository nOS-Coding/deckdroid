#!/data/data/com.termux/files/usr/bin/bash
# decksniff — tcpdump wrapper for DeckDroid
# Usage: decksniff [--json] [--log] [--profile <name>] [tcpdump args...]

LOG_DIR="$HOME/.deckdroid/logs"
JSON_OUT=false
DO_LOG=false
PROFILE="quick"
TCPDUMP_ARGS="-c 10 -q"

i=1
while [ $i -le $# ]; do
  eval "arg=\${$i}"
  case $arg in
    --json) JSON_OUT=true ;;
    --log)  DO_LOG=true ;;
    --profile)
      i=$((i+1))
      eval "PROFILE=\${$i}"
      ;;
    *) break ;;
  esac
  i=$((i+1))
done
shift $((i-1))

TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

# Check if tcpdump is installed
if ! command -v tcpdump &>/dev/null; then
  echo -e "\033[1;33m⚠ tcpdump not installed.\033[0m"
  echo -e "Install: \033[1mpkg install tcpdump\033[0m"
  exit 1
fi

# Profile presets
case "$PROFILE" in
  quick)
    DESC="Quick capture (10 packets, quiet)"
    ;;
  dns)
    DESC="DNS queries only"
    TCPDUMP_ARGS="-c 50 port 53"
    ;;
  http)
    DESC="HTTP traffic"
    TCPDUMP_ARGS="-c 50 port 80 or port 443"
    ;;
  all)
    DESC="All traffic (50 packets)"
    TCPDUMP_ARGS="-c 50 -q"
    ;;
  *)
    DESC="Custom: $PROFILE"
    TCPDUMP_ARGS="$PROFILE"
    ;;
esac

if $JSON_OUT; then
  echo "{\"timestamp\":\"$TIMESTAMP\",\"tool\":\"decksniff\",\"profile\":\"$PROFILE\",\"desc\":\"$DESC\",\"args\":\"$TCPDUMP_ARGS $*\"}"
else
  R='\033[0;31m'; G='\033[0;32m'; Y='\033[0;33m'; C='\033[0;36m'; N='\033[0m'; B='\033[1m'
  
  echo -e "${B}${C}╔══════════════════════════════════╗${N}"
  echo -e "${B}${C}║      decksniff  v1.1          ║${N}"
  echo -e "${B}${C}╚══════════════════════════════════╝${N}"
  echo -e "  ${B}Profile   :${N} $PROFILE — $DESC"
  echo -e "  ${B}Time      :${N} $TIMESTAMP"
  echo -e "${Y}Starting capture... (Ctrl+C to stop)${N}\n"
  
  tcpdump $TCPDUMP_ARGS "$@" 2>&1
fi

if $DO_LOG; then
  mkdir -p "$LOG_DIR"
  echo "{\"ts\":\"$TIMESTAMP\",\"tool\":\"decksniff\",\"profile\":\"$PROFILE\"}" >> "$LOG_DIR/tools.log"
fi
