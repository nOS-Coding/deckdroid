#!/usr/bin/env python3
"""termuxdeck-plugin — Plugin management for TermuxDeck OS"""
import sys
import json
import pathlib

TDECK_DIR = pathlib.Path.home() / ".termuxdeck"
CONFIG_FILE = TDECK_DIR / "config.json"

def load_config():
    if not CONFIG_FILE.exists():
        return {}
    with open(CONFIG_FILE, "r") as f:
        return json.load(f)

def save_config(config):
    with open(CONFIG_FILE, "w") as f:
        json.dump(config, f, indent=2)

def register_plugin(name):
    config = load_config()
    plugins = config.get("plugins", [])
    if name not in plugins:
        plugins.append(name)
        config["plugins"] = plugins
        save_config(config)
        print(f"✓ Plugin '{name}' registered.")
    else:
        print(f"Plugin '{name}' is already registered.")

def unregister_plugin(name):
    config = load_config()
    plugins = config.get("plugins", [])
    if name in plugins:
        plugins.remove(name)
        config["plugins"] = plugins
        save_config(config)
        print(f"✓ Plugin '{name}' unregistered.")
    else:
        print(f"Plugin '{name}' not found.")

def list_plugins():
    config = load_config()
    plugins = config.get("plugins", [])
    print("Registered Plugins:")
    for p in plugins:
        print(f"  - {p}")

def usage():
    print("Usage: termuxdeck-plugin <command> <name>")
    print("Commands:")
    print("  register <name>    Register a new plugin")
    print("  unregister <name>  Unregister a plugin")
    print("  list               List all registered plugins")
    sys.exit(1)

if __name__ == "__main__":
    if len(sys.argv) < 2:
        usage()
    
    cmd = sys.argv[1]
    if cmd == "register":
        if len(sys.argv) < 3: usage()
        register_plugin(sys.argv[2])
    elif cmd == "unregister":
        if len(sys.argv) < 3: usage()
        unregister_plugin(sys.argv[2])
    elif cmd == "list":
        list_plugins()
    else:
        usage()
