#!/usr/bin/env python3
"""deckai — AI launcher for DeckDroid"""
import sys
import os
import subprocess

BOLD   = "\033[1m"
GREEN  = "\033[0;32m"
CYAN   = "\033[0;36m"
YELLOW = "\033[1;33m"
RED    = "\033[0;31m"
RESET  = "\033[0m"

def check_opencode():
    return os.system("which opencode > /dev/null 2>&1") == 0

def check_gemini():
    return os.system("which gemini-cli > /dev/null 2>&1") == 0

def install_opencode():
    print(f"\n{BOLD}Installing opencode...{RESET}\n")
    try:
        subprocess.run(["npm", "install", "-g", "@opencode/opencode"], check=True)
        print(f"{GREEN}✓ opencode installed!{RESET}")
        return True
    except Exception as e:
        print(f"{RED}✗ Failed: {e}{RESET}")
        return False

def install_gemini():
    print(f"\n{BOLD}Installing gemini-cli...{RESET}\n")
    try:
        subprocess.run(["npm", "install", "-g", "@google/gemini-cli"], check=True)
        print(f"{GREEN}✓ gemini-cli installed!{RESET}")
        return True
    except Exception as e:
        print(f"{RED}✗ Failed: {e}{RESET}")
        return False

def launch_opencode():
    print(f"\n{GREEN}Launching opencode...{RESET}\n")
    try:
        subprocess.run(["opencode"])
    except KeyboardInterrupt:
        print(f"\n{YELLOW}Closed.{RESET}")

def launch_gemini():
    print(f"\n{GREEN}Launching gemini-cli...{RESET}\n")
    try:
        subprocess.run(["gemini-cli"])
    except KeyboardInterrupt:
        print(f"\n{YELLOW}Closed.{RESET}")

def interactive_menu():
    print(f"\n{BOLD}deckai — AI Launcher{RESET}\n")
    
    opencode_ok = check_opencode()
    gemini_ok = check_gemini()
    
    print(f"{BOLD}Available AI Tools:{RESET}")
    
    choices = []
    
    if opencode_ok:
        print(f"  {GREEN}[O]{RESET} opencode")
        choices.append(("o", launch_opencode))
    
    if gemini_ok:
        print(f"  {GREEN}[G]{RESET} gemini-cli")
        choices.append(("g", launch_gemini))
    
    print(f"  {YELLOW}[I]{RESET} Install opencode")
    print(f"  {YELLOW}[M]{RESET} Install gemini-cli")
    print(f"  {RED}[Q]{RESET} Quit")
    print()
    
    while True:
        try:
            choice = input(f"{BOLD}Select [{GREEN}O{GREEN}/{GREEN}G{YELLOW}/{YELLOW}I{YELLOW}/{YELLOW}M{RED}/{RED}Q{BOLD}]: {RESET}").strip().lower()
        except (EOFError, KeyboardInterrupt):
            print(f"\n\n{YELLOW}Goodbye!{RESET}\n")
            sys.exit(0)
        
        if choice == "o" and opencode_ok:
            launch_opencode()
            break
        elif choice == "g" and gemini_ok:
            launch_gemini()
            break
        elif choice == "i":
            if install_opencode():
                opencode_ok = True
                choices.append(("o", launch_opencode))
        elif choice == "m":
            if install_gemini():
                gemini_ok = True
                choices.append(("g", launch_gemini))
        elif choice == "q":
            print(f"\n{YELLOW}Goodbye!{RESET}\n")
            break
        else:
            print(f"{RED}Invalid choice: {choice}{RESET}")

if __name__ == "__main__":
    if len(sys.argv) > 1:
        if sys.argv[1] == "opencode" and check_opencode():
            launch_opencode()
        elif sys.argv[1] == "gemini" and check_gemini():
            launch_gemini()
        else:
            print(f"{RED}Usage: deckai [opencode|gemini]{RESET}")
            print(f"Or run without arguments for interactive menu.")
    else:
        interactive_menu()
