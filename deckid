#!/data/data/com.termux/files/usr/bin/bash
# deckid — Deep device identity and network footprint for TermuxDeck OS
# Usage: deckid [--json] [--log] [--public]

LOG_DIR="$HOME/.termuxdeck/logs"
CONFIG="$HOME/.termuxdeck/config.json"
JSON_OUT=false
DO_LOG=false
SHOW_PUBLIC=false

for arg in "$@"; do
  case $arg in
    --json)   JSON_OUT=true ;;
    --log)    DO_LOG=true ;;
    --public) SHOW_PUBLIC=true ;;
  esac
done

TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

# ── Hostname (TermuxDeck config or system) ────────────────────────────────────
if [ -f "$CONFIG" ] && command -v python3 &>/dev/null; then
  HOSTNAME_DECK=$(python3 -c "import json; d=json.load(open('$CONFIG')); print(d.get('hostname','N/A'))" 2>/dev/null)
else
  HOSTNAME_DECK=$(hostname 2>/dev/null || echo "N/A")
fi

# ── Network ───────────────────────────────────────────────────────────────────
LOCAL_IP=$(ip addr 2>/dev/null | awk '/inet /{print $2}' | grep -v '127.0.0.1' | head -1 | cut -d/ -f1)
LOCAL_IP=${LOCAL_IP:-"N/A"}

MAC=$(ip link 2>/dev/null | awk '/ether/{print $2}' | grep -v '00:00:00:00:00:00' | head -1)
MAC=${MAC:-"N/A"}

GW=$(ip route 2>/dev/null | awk '/default/{print $3; exit}')
GW=${GW:-"N/A"}

IFACE=$(ip route 2>/dev/null | awk '/default/{print $5; exit}')
IFACE=${IFACE:-"N/A"}

# ── Public IP (optional, requires internet) ───────────────────────────────────
PUBLIC_IP="(use --public to fetch)"
if $SHOW_PUBLIC && command -v curl &>/dev/null; then
  PUBLIC_IP=$(curl -s --max-time 5 "https://api.ipify.org" 2>/dev/null || echo "N/A")
fi

# ── Termux:API device info ────────────────────────────────────────────────────
ANDROID_ID="N/A"; IMEI="N/A"; MODEL="N/A"; MANUFACTURER="N/A"
if command -v termux-telephony-deviceinfo &>/dev/null; then
  RAW=$(termux-telephony-deviceinfo 2>/dev/null)
  if [ -n "$RAW" ]; then
    IMEI=$(echo "$RAW"         | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('imei','N/A'))" 2>/dev/null)
    ANDROID_ID=$(echo "$RAW"  | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('device_id','N/A'))" 2>/dev/null)
  fi
fi
if command -v termux-telephony-cellinfo &>/dev/null; then
  RAW2=$(termux-telephony-cellinfo 2>/dev/null)
fi

# Fallback device info from build props (Android)
if command -v getprop &>/dev/null; then
  MODEL=$(getprop ro.product.model 2>/dev/null || echo "N/A")
  MANUFACTURER=$(getprop ro.product.manufacturer 2>/dev/null || echo "N/A")
  ANDROID_VER=$(getprop ro.build.version.release 2>/dev/null || echo "N/A")
else
  ANDROID_VER=$(uname -r 2>/dev/null || echo "N/A")
  MODEL="N/A"; MANUFACTURER="N/A"
fi

ARCH=$(uname -m 2>/dev/null || echo "N/A")
KERNEL=$(uname -r 2>/dev/null || echo "N/A")
UPTIME=$(uptime -p 2>/dev/null || uptime 2>/dev/null | awk '{print $3,$4}' | tr -d ',')

if $JSON_OUT; then
  python3 -c "
import json
print(json.dumps({
  'timestamp':    '$TIMESTAMP',
  'hostname':     '$HOSTNAME_DECK',
  'architecture': '$ARCH',
  'kernel':       '$KERNEL',
  'android':      '$ANDROID_VER',
  'manufacturer': '$MANUFACTURER',
  'model':        '$MODEL',
  'imei':         '$IMEI',
  'android_id':   '$ANDROID_ID',
  'local_ip':     '$LOCAL_IP',
  'public_ip':    '$PUBLIC_IP',
  'mac':          '$MAC',
  'gateway':      '$GW',
  'interface':    '$IFACE',
  'uptime':       '$UPTIME',
}, indent=2))
"
else
  R='\033[0;31m'; C='\033[0;36m'; M='\033[0;35m'; Y='\033[0;33m'; N='\033[0m'; B='\033[1m'
  echo -e "${B}${C}╔══════════════════════════════════╗${N}"
  echo -e "${B}${C}║         deckid  v1.0             ║${N}"
  echo -e "${B}${C}╚══════════════════════════════════╝${N}"
  echo -e "${B}${M}── Device ──────────────────────────${N}"
  echo -e "  ${B}Hostname     :${N} $HOSTNAME_DECK"
  echo -e "  ${B}Manufacturer :${N} $MANUFACTURER"
  echo -e "  ${B}Model        :${N} $MODEL"
  echo -e "  ${B}Android      :${N} $ANDROID_VER"
  echo -e "  ${B}Architecture :${N} $ARCH"
  echo -e "  ${B}Kernel       :${N} $KERNEL"
  echo -e "  ${B}Uptime       :${N} $UPTIME"
  echo -e "${B}${M}── Identity ─────────────────────────${N}"
  echo -e "  ${B}IMEI         :${N} ${R}$IMEI${N}"
  echo -e "  ${B}Android ID   :${N} $ANDROID_ID"
  echo -e "${B}${M}── Network ──────────────────────────${N}"
  echo -e "  ${B}Interface    :${N} $IFACE"
  echo -e "  ${B}Local IP     :${N} $LOCAL_IP"
  echo -e "  ${B}Public IP    :${N} $PUBLIC_IP"
  echo -e "  ${B}MAC          :${N} $MAC"
  echo -e "  ${B}Gateway      :${N} $GW"
  echo -e "  ${B}Time         :${N} $TIMESTAMP"
fi

if $DO_LOG; then
  mkdir -p "$LOG_DIR"
  echo "{\"ts\":\"$TIMESTAMP\",\"tool\":\"deckid\",\"hostname\":\"$HOSTNAME_DECK\",\"model\":\"$MODEL\",\"local_ip\":\"$LOCAL_IP\",\"arch\":\"$ARCH\"}" >> "$LOG_DIR/tools.log"
fi
