#!/usr/bin/env bash
# decknote вЂ” Plain-text markdown notes for DeckDroid
# Usage: decknote [new|list|view|edit|delete|search] [args...]

DDROID_HOME="${DDROID_HOME:-$HOME/.deckdroid}"
NOTES_DIR="$DDROID_HOME/notes"
TRASH_DIR="$NOTES_DIR/.trash"
EDITOR="${EDITOR:-nano}"

# Ensure directories exist
mkdir -p "$NOTES_DIR" "$TRASH_DIR"

R='\033[0;31m'; G='\033[0;32m'; Y='\033[1;33m'; C='\033[0;36m'; N='\033[0m'; B='\033[1m'

case "${1:-}" in
  new)
    # Create new note
    TITLE="${2:-Untitled}"
    FILENAME=$(echo "$TITLE" | tr ' ' '_' | tr -cd 'a-zA-Z0-9_-').md
    FILEPATH="$NOTES_DIR/$FILENAME"
    
    if [ -f "$FILEPATH" ]; then
      echo -e "${Y}Note already exists: $FILENAME${N}"
      FILEPATH="$NOTES_DIR/${TILENAME%.md}_$(date +%s).md"
    fi
    
    DATE=$(date "+%Y-%m-%d %H:%M")
    cat > "$FILEPATH" <<NOTE
# $TITLE

**Date:** $DATE

---
NOTE
    echo -e "${G}вњ“ Created: $FILEPATH${N}"
    echo -e "${C}Opening in $EDITOR...${N}"
    $EDITOR "$FILEPATH"
    ;;
  
  list|ls)
    # List all notes
    echo -e "${B}${C}в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—${N}"
    echo -e "${B}${C}в•‘       decknote вЂ” Notes List        в•‘${N}"
    echo -e "${B}${C}в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ${N}"
    echo ""
    
    if [ -z "$(ls -A "$NOTES_DIR"/*.md 2>/dev/null)" ]; then
      echo -e "${Y}No notes yet. Create one: decknote new \"My Note\"${N}"
    else
      count=0
      for note in "$NOTES_DIR"/*.md; do
        [ -f "$note" ] || continue
        count=$((count+1))
        title=$(head -1 "$note" | sed 's/^# //')
        modified=$(stat -c %y "$note" 2>/dev/null | cut -d. -f1 || echo "N/A")
        printf "${C}%2d${N}) %-30s ${DIM}%s${N}\n" "$count" "$title" "$modified"
      done
    fi
    echo ""
    ;;
  
  view|show)
    # View a note
    if [ -z "${2:-}" ]; then
      echo -e "${R}Usage: decknote view <filename>${N}"
      exit 1
    fi
    FILE="$NOTES_DIR/${2%.md}.md"
    if [ ! -f "$FILE" ]; then
      echo -e "${R}Note not found: $2${N}"
      exit 1
    fi
    cat "$FILE" | less +G
    ;;
  
  edit)
    # Edit a note
    if [ -z "${2:-}" ]; then
      echo -e "${R}Usage: decknote edit <filename>${N}"
      exit 1
    fi
    FILE="$NOTES_DIR/${2%.md}.md"
    if [ ! -f "$FILE" ]; then
      echo -e "${R}Note not found: $2${N}"
      exit 1
    fi
    $EDITOR "$FILE"
    ;;
  
  delete|rm)
    # Move note to trash
    if [ -z "${2:-}" ]; then
      echo -e "${R}Usage: decknote delete <filename>${N}"
      exit 1
    fi
    FILE="$NOTES_DIR/${2%.md}.md"
    if [ ! -f "$FILE" ]; then
      echo -e "${R}Note not found: $2${N}"
      exit 1
    fi
    mv "$FILE" "$TRASH_DIR/"
    echo -e "${G}вњ“ Moved to trash: $2${N}"
    ;;
  
  search)
    # Search in notes
    QUERY="${2:-}"
    if [ -z "$QUERY" ]; then
      echo -e "${R}Usage: decknote search <query>${N}"
      exit 1
    fi
    echo -e "${B}${C}Search results for: $QUERY${N}\n"
    grep -r -i "$QUERY" "$NOTES_DIR"/*.md 2>/dev/null | head -20 | while IFS=: read -r file line content; do
      title=$(head -1 "$file" | sed 's/^# //')
      echo -e "${C}$title${N}: $content"
    done
    ;;
  
  *)
    # Show help
    echo -e "${B}${C}в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—${N}"
    echo -e "${B}${C}в•‘       decknote вЂ” Help                в•‘${N}"
    echo -e "${B}${C}в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ${N}"
    echo ""
    echo -e "${B}Usage:${N} decknote <command> [args...]"
    echo ""
    echo -e "${B}Commands:${N}"
    echo -e "  ${C}new${N} <title>      Create a new note"
    echo -e "  ${C}list${N}            List all notes"
    echo -e "  ${C}view${N} <file>     View a note (less)"
    echo -e "  ${C}edit${N} <file>     Edit a note"
    echo -e "  ${C}delete${N} <file>   Move to trash"
    echo -e "  ${C}search${N} <query>  Search in notes"
    echo ""
    echo -e "${B}Examples:${N}"
    echo -e "  decknote new \"Meeting Notes\""
    echo -e "  decknote list"
    echo -e "  decknote search project"
    ;;
esac
