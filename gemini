#!/usr/bin/env python3
"""gemini — TermuxDeck AI assistant wrapper"""
import os, sys, subprocess, shutil

def main():
    gemini_cmd = shutil.which("gemini-chat") or shutil.which("gemini")

    if not gemini_cmd:
        print("Gemini CLI not installed. Installing...")
        result = subprocess.run(
            ["npm", "install", "-g", "@google/gemini-cli"],
            capture_output=True, text=True
        )
        if result.returncode != 0:
            print("Installation failed:")
            print(result.stderr)
            sys.exit(1)
        gemini_cmd = shutil.which("gemini-chat") or shutil.which("gemini")
        if not gemini_cmd:
            print("Failed to find gemini after install.")
            sys.exit(1)

    os.execv(gemini_cmd, [gemini_cmd] + sys.argv[1:])

if __name__ == "__main__":
    main()