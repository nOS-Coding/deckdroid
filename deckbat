#!/usr/bin/env python3
"""deckbat — Battery status for TermuxDeck OS"""
import sys, json, subprocess, os

JSON_OUT = "--json" in sys.argv
LOG_OUT  = "--log" in sys.argv

def get_battery_termux():
    try:
        result = subprocess.run(["termux-battery-status"], capture_output=True, text=True, timeout=5)
        return json.loads(result.stdout)
    except Exception:
        return None

def get_battery_linux():
    """Fallback: read from /sys/class/power_supply"""
    base = "/sys/class/power_supply"
    data = {}
    try:
        for name in os.listdir(base):
            path = f"{base}/{name}"
            t = open(f"{path}/type").read().strip() if os.path.exists(f"{path}/type") else ""
            if t == "Battery":
                data["percentage"] = int(open(f"{path}/capacity").read()) if os.path.exists(f"{path}/capacity") else None
                status_raw = open(f"{path}/status").read().strip() if os.path.exists(f"{path}/status") else "Unknown"
                data["status"] = status_raw.lower()
                if os.path.exists(f"{path}/temp"):
                    data["temperature"] = int(open(f"{path}/temp").read()) / 10
                break
    except Exception:
        pass
    return data if data else None

bat = get_battery_termux() or get_battery_linux() or {}

if JSON_OUT:
    print(json.dumps(bat, indent=2))
else:
    GREEN = "\033[0;32m"; RED = "\033[0;31m"; YELLOW = "\033[1;33m"; RESET = "\033[0m"; BOLD = "\033[1m"
    pct = bat.get("percentage", "?")
    status = bat.get("status", "unknown")
    temp = bat.get("temperature", "?")

    color = GREEN if isinstance(pct, int) and pct > 50 else (YELLOW if isinstance(pct, int) and pct > 20 else RED)
    bar_len = int(pct / 5) if isinstance(pct, int) else 0
    bar = "█" * bar_len + "░" * (20 - bar_len)

    print(f"\n{BOLD}deckbat — Battery Status{RESET}")
    print(f"  Level:  {color}[{bar}]{RESET} {pct}%")
    print(f"  Status: {status}")
    print(f"  Temp:   {temp}°C\n")

if LOG_OUT:
    import datetime, pathlib
    log_path = pathlib.Path.home() / ".termuxdeck/logs/tools.log"
    with open(log_path, "a") as f:
        f.write(json.dumps({"time": datetime.datetime.utcnow().isoformat()+"Z", "tool": "deckbat", "result": bat}) + "\n")
