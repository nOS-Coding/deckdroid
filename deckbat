#!/data/data/com.termux/files/usr/bin/bash
# deckbat вЂ” Advanced battery metrics for DeckDroid
# Usage: deckbat [--json] [--log] [--alert <percent>]

LOG_DIR="$HOME/.deckdroid/logs"
JSON_OUT=false
DO_LOG=false
ALERT_THRESHOLD=-1

i=1
arg_count=${#:-0}
while [ "$i" -le "$arg_count" ]; do
  eval "arg=\${$i}"
  case $arg in
    --json)  JSON_OUT=true ;;
    --log)   DO_LOG=true ;;
    --alert) i=$((i+1)); eval "ALERT_THRESHOLD=\${$i}" ;;
  esac
  i=$((i+1))
done

TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

if command -v termux-battery-status &>/dev/null; then
  RAW=$(termux-battery-status 2>/dev/null)
  LEVEL=$(echo "$RAW" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('percentage','N/A'))" 2>/dev/null)
  STATUS=$(echo "$RAW" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('status','N/A'))" 2>/dev/null)
  TEMP=$(echo "$RAW" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('temperature','N/A'))" 2>/dev/null)
  VOLTAGE=$(echo "$RAW" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('voltage','N/A'))" 2>/dev/null)
  HEALTH=$(echo "$RAW" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('health','N/A'))" 2>/dev/null)
  PLUGGED=$(echo "$RAW" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('plugged','N/A'))" 2>/dev/null)
else
  SYS="/sys/class/power_supply/battery"
  LEVEL=$(cat "$SYS/capacity" 2>/dev/null || echo "N/A")
  STATUS=$(cat "$SYS/status"  2>/dev/null || echo "N/A")
  T=$(cat "$SYS/temp" 2>/dev/null)
  TEMP=${T:+"$(awk "BEGIN {printf \"%.1f\", $T/10}")"}; TEMP=${TEMP:-N/A}
  V=$(cat "$SYS/voltage_now" 2>/dev/null)
  VOLTAGE=${V:+"$(awk "BEGIN {printf \"%.3f\", $V/1000000}")"}; VOLTAGE=${VOLTAGE:-N/A}
  HEALTH=$(cat "$SYS/health" 2>/dev/null || echo "N/A")
  PLUGGED="N/A"
fi

if $JSON_OUT; then
  python3 -c "
import json
print(json.dumps({
  'timestamp':'$TIMESTAMP','level':'$LEVEL','status':'$STATUS',
  'temperature_c':'$TEMP','voltage_v':'$VOLTAGE','health':'$HEALTH','plugged':'$PLUGGED'
}, indent=2))
"
else
  R='\033[0;31m'; Y='\033[0;33m'; G='\033[0;32m'; C='\033[0;36m'; N='\033[0m'; B='\033[1m'
  LC=$N
  if [ -n "$LEVEL" ] && [ "$LEVEL" != "N/A" ] && echo "$LEVEL" | grep -q '^[0-9]\+$' 2>/dev/null; then
    if [ "$LEVEL" -le 15 ] 2>/dev/null; then LC=$R; elif [ "$LEVEL" -le 40 ] 2>/dev/null; then LC=$Y; else LC=$G; fi
  fi
  echo -e "${B}${C}в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—${N}"
  echo -e "${B}${C}в•‘      deckbat  v1.1       в•‘${N}"
  echo -e "${B}${C}в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ${N}"
  echo -e "  ${B}Level   :${N}  ${LC}${LEVEL}%${N}"
  echo -e "  ${B}Status  :${N}  $STATUS"
  echo -e "  ${B}Health  :${N}  $HEALTH"
  echo -e "  ${B}Temp    :${N}  ${TEMP}В°C"
  echo -e "  ${B}Voltage :${N}  ${VOLTAGE} V"
  echo -e "  ${B}Plugged :${N}  $PLUGGED"
  echo -e "  ${B}Time    :${N}  $TIMESTAMP"
  if [ "$ALERT_THRESHOLD" -gt 0 ] 2>/dev/null && [ -n "$LEVEL" ] && [ "$LEVEL" != "N/A" ] && echo "$LEVEL" | grep -q '^[0-9]\+$' 2>/dev/null && [ "$LEVEL" -le "$ALERT_THRESHOLD" ] 2>/dev/null; then
    echo -e "\n  ${R}${B}вљ  ALERT: Battery at ${LEVEL}% (threshold: ${ALERT_THRESHOLD}%)${N}"
    command -v termux-notification &>/dev/null && termux-notification --title "deckbat ALERT" --content "Battery at ${LEVEL}%" 2>/dev/null
  fi
fi

if $DO_LOG; then
  mkdir -p "$LOG_DIR"
  echo "{\"ts\":\"$TIMESTAMP\",\"tool\":\"deckbat\",\"level\":\"$LEVEL\",\"status\":\"$STATUS\",\"temp\":\"$TEMP\",\"voltage\":\"$VOLTAGE\",\"health\":\"$HEALTH\"}" >> "$LOG_DIR/tools.log"
fi
