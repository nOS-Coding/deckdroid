#!/usr/bin/env python3
"""deckmenu — Interactive TUI launcher for DeckDroid"""
import sys
import os
import subprocess

BOLD   = "\033[1m"
GREEN  = "\033[0;32m"
CYAN   = "\033[0;36m"
YELLOW = "\033[1;33m"
RESET  = "\033[0m"
DIM    = "\033[2m"

MENU_ITEMS = [
    ("deckbat",      "Battery metrics"),
    ("deckping",     "Connectivity check"),
    ("deckid",       "Device identity"),
    ("deckclock",    "World clock"),
    ("deckwifi",     "WiFi scanner"),
    ("decklocate",   "Location services"),
    ("decksniff",   "Packet capture"),
    ("decknote",     "Notes system"),
    ("deckbrowse",   "Terminal browser"),
    ("deckdisk",     "Disk management"),
    ("decklog",      "Log viewer"),
    ("deckclean",    "Cleanup utility"),
    ("deckupdate",   "Update manager"),
    ("decktheme",    "Theme manager"),
    ("decksetup",   "Setup wizard"),
    ("deckai",       "AI launcher"),
    ("tetris",      "Tetris game"),
]

def clear_screen():
    os.system('clear')

def draw_menu(selected):
    clear_screen()
    print(f"{BOLD}{CYAN}")
    print("╔══════════════════════════════════════════╗")
    print("║      deckmenu — Interactive Launcher     ║")
    print("╚══════════════════════════════════════════╝")
    print(f"{RESET}\n")
    
    print(f"{DIM}Use number keys (1-9, 0) to select, 'q' to quit{RESET}\n")
    
    for idx, (cmd, desc) in enumerate(MENU_ITEMS):
        num = idx + 1
        if num == selected:
            print(f"  {GREEN}▶ {num:2d}. {cmd}{RESET} — {desc}")
        else:
            print(f"      {num:2d}. {CYAN}{cmd}{RESET} — {desc}")
    
    print(f"\n{DIM}{'─' * 40}{RESET}")
    print(f"{DIM}Enter choice: {RESET}", end="")

def run_tool(cmd):
    print(f"\n{YELLOW}Launching {cmd}...{RESET}\n")
    try:
        subprocess.run([cmd])
    except FileNotFoundError:
        print(f"{RED}Tool not found: {cmd}{RESET}")
        print(f"Try running: decksetup")
    except KeyboardInterrupt:
        pass
    input(f"\n{DIM}Press Enter to continue...{RESET}")

def main():
    selected = 1
    total = len(MENU_ITEMS)
    
    while True:
        draw_menu(selected)
        
        try:
            choice = input().strip().lower()
        except (EOFError, KeyboardInterrupt):
            print(f"\n\n{YELLOW}Goodbye!{RESET}\n")
            break
        
        if choice == 'q':
            print(f"\n{YELLOW}Goodbye!{RESET}\n")
            break
        
        if choice.isdigit():
            num = int(choice)
            if 1 <= num <= total:
                selected = num
                run_tool(MENU_ITEMS[num-1][0])
            else:
                print(f"\n{YELLOW}Invalid choice: {num}{RESET}")
                import time
                time.sleep(1)
        else:
            print(f"\n{YELLOW}Invalid input: {choice}{RESET}")
            import time
            time.sleep(1)

if __name__ == "__main__":
    main()
