#!/usr/bin/env python3
"""deckhelp — Help utility for DeckDroid"""
import sys, os, pathlib

DDROID = pathlib.Path.home() / ".deckdroid"
GREEN = "\033[0;32m"; YELLOW = "\033[1;33m"; CYAN = "\033[0;36m"; RESET = "\033[0m"; BOLD = "\033[1m"

def show_main_help():
    print(f"""
{BOLD}{CYAN}
╔═════════════════════════════════════════════╗
║           DeckDroid — Help System              ║
╚═════════════════════════════════════════════╝
{RESET}
{BOLD}Cyberdeck Tools:{RESET}
  {CYAN}deckbat{RESET}      — Advanced battery metrics (temp, voltage, health)
  {CYAN}deckping{RESET}     — Multi-layer connectivity audit
  {CYAN}deckid{RESET}       — Deep device identity and network footprint
  {CYAN}deckwifi{RESET}     — WiFi scanner with signal bars
  {CYAN}decklocate{RESET}   — GPS + cell tower triangulation
  {CYAN}deckclock{RESET}    — Multi-timezone world clock
  {CYAN}decksniff{RESET}    — tcpdump wrapper with preset profiles
  {CYAN}decknote{RESET}     — Plain-text markdown notes
  {CYAN}deckbrowse{RESET}   — Universal terminal browser (w3m/lynx)
  {CYAN}deckdisk{RESET}     — Disk management
  {CYAN}decklog{RESET}      — Log viewer
  {CYAN}deckclean{RESET}    — Storage cleanup
  {CYAN}deckupdate{RESET}   — Check & apply updates
  {CYAN}decktheme{RESET}    — Theme manager (8 themes + 7 profile themes)
  {CYAN}deckmenu{RESET}     — Interactive TUI launcher
  {CYAN}deckai{RESET}       — AI launcher (opencode / gemini-cli)
  {CYAN}tetris{RESET}       — Play Tetris game

{BOLD}Repository Tools:{RESET}
  {CYAN}ddeckconf{RESET}    — Config manager (get/set/list/validate)
  {CYAN}ddeckprof{RESET}    — Profile manager (set/unset/list)
  {CYAN}deckdroid-doctor{RESET} — System health audit
  {CYAN}deckdroid-sync{RESET}    — Multi-device config sync
  {CYAN}deckdroid-web{RESET}    — Local web dashboard
  {CYAN}deckdroid-plugin{RESET} — Plugin registry manager
  {CYAN}deckdroid-vault{RESET}  — GPG encryption for config

{BOLD}Quick Commands:{RESET}
  {CYAN}decksetup{RESET}    — First-run setup wizard
  {CYAN}deckhelp{RESET}     — Show this help
  {CYAN}zsh{RESET}         — Start DeckDroid shell
  {CYAN}uninstall.sh{RESET} — Uninstall DeckDroid

{BOLD}Usage Examples:{RESET}
  deckbat --json              # JSON output
  deckping --host 8.8.8.8     # Custom host
  deckbrowse github           # Search or open URL
  decktheme set nord           # Set theme
  ddeckconf get hostname       # Get config value
  ddeckprof set hacker        # Activate profile
  tetris                     # Play Tetris
""")

def show_tool_help(tool):
    """Show help for a specific tool."""
    help_text = {
        "deckbat": """
{CYAN}deckbat{RESET} — Battery Metrics
{BOLD}Usage:{RESET} deckbat [--json] [--log] [--alert <pct>]

  Shows battery level, status, temperature, voltage, health.
  Requires Termux:API: pkg install termux-api

{BOLD}Options:{RESET}
  --json    Output as JSON
  --log     Log to ~/.deckdroid/logs/tools.log
  --alert   Alert when battery below threshold

{BOLD}Examples:{RESET}
  deckbat
  deckbat --json
  deckbat --alert 20
""",
        "deckping": """
{CYAN}deckping{RESET} — Connectivity Audit
{BOLD}Usage:{RESET} deckping [--json] [--log] [--host <addr>]

  Checks: Gateway → DNS → Internet → HTTP latency.

{BOLD}Options:{RESET}
  --json      Output as JSON
  --log       Log to ~/.deckdroid/logs/tools.log
  --host      Check custom host

{BOLD}Examples:{RESET}
  deckping
  deckping --host google.com
""",
        "deckbrowse": """
{CYAN}deckbrowse{RESET} — Terminal Browser
{BOLD}Usage:{RESET} deckbrowse [url|query]

  Universal browser using w3m/lynx/browsh.
  Press Enter to submit searches.

{BOLD}Examples:{RESET}
  deckbrowse                    # Interactive launcher
  deckbrowse github           # Opens GitHub
  deckbrowse "weather today"   # Google search
""",
        "decktheme": """
{CYAN}decktheme{RESET} — Theme Manager
{BOLD}Usage:{RESET} decktheme <command>

{BOLD}Visual Themes:{RESET} cyberpunk, ghost, blood, matrix, nord, dracula, monokai, ocean
{BOLD}Profile Themes:{RESET} hacker, developer, writer, crypto, radio, hamradio, iot

{BOLD}Examples:{RESET}
  decktheme list              # List all themes
  decktheme set nord           # Set visual theme
  decktheme set hacker        # Set profile theme
""",
        "ddeckconf": """
{CYAN}ddeckconf{RESET} — Config Manager
{BOLD}Usage:{RESET} ddeckconf <command> [args...]

{BOLD}Commands:{RESET}
  get <key>       Get config value (dot notation)
  set <key> <val>  Set config value
  list             List all config
  validate         Validate config.json

{BOLD}Examples:{RESET}
  ddeckconf get hostname
  ddeckconf set theme.name ghost
  ddeckconf list
""",
        "ddeckprof": """
{CYAN}ddeckprof{RESET} — Profile Manager
{BOLD}Usage:{RESET} ddeckprof <command> [args...]

{BOLD}Commands:{RESET}
  list             Show available profiles
  set <name>       Install and activate profile
  unset <name>     Deactivate profile
  install-all      Install all profiles
  status           Show active profiles

{BOLD}Profiles:{RESET} hacker, developer, writer, crypto, radio, hamradio, iot

{BOLD}Examples:{RESET}
  ddeckprof list
  ddeckprof set writer
  ddeckprof status
""",
    }
    
    if tool in help_text:
        print(help_text[tool].format(GREEN=GREEN, YELLOW=YELLOW, CYAN=CYAN, RESET=RESET, BOLD=BOLD))
    else:
        print(f"Unknown tool: {tool}")
        print(f"Run {CYAN}deckhelp{RESET} to see all tools.")

if __name__ == "__main__":
    args = sys.argv[1:]
    
    if not args:
        show_main_help()
    else:
        show_tool_help(args[0].lower())
