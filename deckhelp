def cmd_list():
    print(f"\n{BOLD}{CYAN}╔═══════════════════════════════════════════════════════════╗{RESET}")
    print(f"{BOLD}{CYAN}║              TermuxDeck OS — Help Index                      ║{RESET}")
    print(f"{BOLD}{CYAN}╚═══════════════════════════════════════════════════════════╝{RESET}\n")
    
    current_cat = None
    for name in sorted(TOOLS.keys()):
        info = TOOLS[name]
        if info["category"] != current_cat:
            current_cat = info["category"]
            print(f"\n{BOLD}{YELLOW}── {current_cat}{RESET}\n")
        print(f"  {CYAN}{name:<22}{RESET}  {info['desc']}")
    print(f"\n{BOLD}Usage:{RESET} deckhelp <tool>     Show detailed help")
    print(f"        {BOLD}deckhelp all{RESET}    Show all tool details")
    print(f"        {BOLD}deckhelp --cat{RESET}  Show by category")
    print()

def cmd_tool(name):
    if name not in TOOLS:
        print(f"{YELLOW}Unknown tool: {name}{RESET}")
        print(f"Run 'deckhelp' to list all tools.")
        return
    
    info = TOOLS[name]
    print(f"\n{BOLD}{CYAN}── {name}{RESET}")
    print(f"  Category:  {info['category']}")
    print(f"  Description: {info['desc']}")
    print(f"\n  {BOLD}Usage:{RESET}")
    print(f"    {info['usage']}")
    print(f"\n  {BOLD}Examples:{RESET}")
    for ex in info["examples"]:
        print(f"    {CYAN}$ {ex}{RESET}")
    print()

def cmd_all():
    for name in sorted(TOOLS.keys()):
        cmd_tool(name)

def cmd_by_category():
    cats = {}
    for name, info in TOOLS.items():
        cat = info["category"]
        if cat not in cats:
            cats[cat] = []
        cats[cat].append(name)
    
    for cat, tools in cats.items():
        print(f"\n{BOLD}{YELLOW}══ {cat} ══════════════════════════════════════════════{RESET}\n")
        for t in tools:
            print(f"  {CYAN}{t:<22}{RESET}  {TOOLS[t]['desc']}")
    print()

CMDS = {"list": cmd_list, "all": cmd_all, "--cat": cmd_by_category}

if __name__ == "__main__":
    args = sys.argv[1:]
    
    if not args:
        cmd_list()
    elif args[0] in CMDS:
        CMDS[args[0]]()
    elif args[0] in TOOLS:
        cmd_tool(args[0])
    elif args[0] == "--help" or args[0] == "-h":
        print(f"{BOLD}deckhelp — TermuxDeck OS Help{RESET}")
        print(f"Usage: deckhelp [tool name]")
        print(f"       deckhelp list      # List all tools")
        print(f"       deckhelp all      # Show all details")
        print(f"       deckhelp --cat    # Group by category")
    else:
        print(f"{YELLOW}Unknown: {args[0]}{RESET}")
        cmd_list()