#!/usr/bin/env python3
"""ddeckprof — DeckDroid Profile Manager"""
import sys, subprocess, os, pathlib

HOME = pathlib.Path.home()
DDROID = HOME / ".deckdroid"
CFG = DDROID / "config.json"
PROFILES_DIR = DDROID / "profiles"

PROFILES = {
    "hacker": {
        "pkgs": ["nmap", "netcat-openbsd", "curl", "wget", "tcpdump", "tshark", "whois", "dnsutils"],
        "desc": "Security research tools (nmap, tcpdump, etc.)",
    },
    "developer": {
        "pkgs": ["git", "openssh", "python", "nodejs", "nano"],
        "desc": "Development environment (git, python, nodejs)",
    },
    "writer": {
        "pkgs": ["mdcat", "pandoc"],
        "desc": "Writing tools (markdown, pandoc)",
    },
    "crypto": {
        "pkgs": ["gnupg", "openssl"],
        "desc": "Encryption tools (GPG, openssl)",
    },
    "radio": {
        "pkgs": ["rtl-sdr", "sox", "multimon-ng"],
        "desc": "SDR tools (RTL-SDR, radio decode)",
    },
    "hamradio": {
        "pkgs": ["hamlib"],
        "desc": "Amateur radio tools",
    },
    "iot": {
        "pkgs": ["python", "mosquitto-clients"],
        "desc": "IoT tools (serial, MQTT)",
    },
}

def load_cfg():
    if CFG.exists():
        return json.loads(CFG.read_text())
    return {"profiles": []}

def save_cfg(cfg):
    CFG.write_text(json.dumps(cfg, indent=2))

def get_active():
    return load_cfg().get("profiles", [])

def set_active(profile, active=True):
    cfg = load_cfg()
    profiles = cfg.get("profiles", [])
    if active and profile not in profiles:
        profiles.append(profile)
    elif not active and profile in profiles:
        profiles.remove(profile)
    cfg["profiles"] = profiles
    save_cfg(cfg)

def install_pkg(pkg):
    try:
        result = subprocess.run(
            ["pkg", "install", "-y", pkg],
            capture_output=True, text=True, timeout=120
        )
        return result.returncode == 0
    except Exception:
        return False

def cmd_list(args):
    active = get_active()
    print("\nDeckDroid — Available Profiles\n")
    for name, info in PROFILES.items():
        status = "✓ active" if name in active else "○ inactive"
        print(f"  {name:<12} [{status}]  {info['desc']}")
    print()

def cmd_set(args):
    if not args:
        print("Usage: ddeckprof set <profile>")
        print(f"Available: {', '.join(PROFILES.keys())}")
        sys.exit(1)
    
    profile = args[0]
    if profile not in PROFILES:
        print(f"Unknown profile: {profile}")
        sys.exit(1)
    
    print(f"\nInstalling {profile} profile...\n")
    for pkg in PROFILES[profile]["pkgs"]:
        print(f"  Installing {pkg}...", end=" ")
        if install_pkg(pkg):
            print("OK")
        else:
            print("skipped (may not be available)")
    
    set_active(profile, True)
    print(f"\n✓ {profile} profile activated")

def cmd_unset(args):
    if not args:
        print("Usage: ddeckprof unset <profile>")
        sys.exit(1)
    profile = args[0]
    if profile not in PROFILES:
        print(f"Unknown profile: {profile}")
        sys.exit(1)
    set_active(profile, False)
    print(f"✓ {profile} profile deactivated")

def cmd_install_all(args):
    for name in PROFILES:
        set_active(name, True)
        print(f"\n[Installing {name}]")
        for pkg in PROFILES[name]["pkgs"]:
            print(f"  {pkg}...", end=" ")
            if install_pkg(pkg):
                print("OK")
            else:
                print("skipped")
    print("\n✓ All profiles installed and activated")

def cmd_status(args):
    active = get_active()
    if active:
        print("Active profiles:")
        for p in active:
            print(f"  • {p}")
    else:
        print("No profiles active. Run: ddeckprof set <profile>")

CMDS = {
    "list": cmd_list,
    "set": cmd_set,
    "unset": cmd_unset,
    "install-all": cmd_install_all,
    "status": cmd_status,
}

if __name__ == "__main__":
    if not DDROID.exists():
        print("DeckDroid not installed.")
        print("Run: curl -sL https://nos-coding.github.io/deckdroid/install.sh | bash")
        sys.exit(1)
    
    args = sys.argv[1:]
    if not args or args[0] not in CMDS:
        print("DeckDroid Profile Manager")
        print("Usage: ddeckprof <command> [args]")
        print("\nCommands:")
        print("  list         Show available profiles")
        print("  set <name>   Install and activate a profile")
        print("  unset <name> Deactivate a profile")
        print("  install-all  Install all profiles")
        print("  status       Show active profiles")
        sys.exit(1)
    
    CMDS[args[0]](args[1:])
