#!/usr/bin/env python3
"""ddeckprof — DeckDroid Profile Manager"""
import sys
import subprocess
import os
import pathlib
import json

HOME = pathlib.Path.home()
DDROID = HOME / ".deckdroid"
CFG = DDROID / "config.json"
PROFILES_DIR = DDROID / "profiles"

GREEN = "\033[0;32m"
YELLOW = "\033[1;33m"
CYAN = "\033[0;36m"
RESET = "\033[0m"
BOLD = "\033[1m"
RED = "\033[0;31m"

PROFILES = {
    "hacker": {
        "name": "hacker",
        "desc": "Penetration testing & security tools",
        "pkgs": ["nmap", "tcpdump", "netcat", "tshark", "whois", "dnsutils"],
        "shell": "hacker.sh",
    },
    "developer": {
        "name": "developer",
        "desc": "Development environment",
        "pkgs": ["git", "openssh", "python", "nodejs", "nano"],
        "shell": "developer.sh",
    },
    "writer": {
        "name": "writer",
        "desc": "Writing & documentation tools",
        "pkgs": ["mdcat", "pandoc"],
        "shell": "writer.sh",
    },
    "crypto": {
        "name": "crypto",
        "desc": "Cryptography & encryption tools",
        "pkgs": ["gnupg", "openssl"],
        "shell": "crypto.sh",
    },
    "radio": {
        "name": "radio",
        "desc": "SDR & radio hacking tools",
        "pkgs": ["rtl-sdr", "sox", "multimon-ng"],
        "shell": "radio.sh",
    },
    "hamradio": {
        "name": "hamradio",
        "desc": "Ham radio tools",
        "pkgs": ["rtl-sdr", "sox"],
        "shell": "hamradio.sh",
    },
    "iot": {
        "name": "iot",
        "desc": "Internet of Things tools",
        "pkgs": ["python", "mosquitto-clients"],
        "shell": "iot.sh",
    },
    "base": {
        "name": "base",
        "desc": "Base profile with essential tools",
        "pkgs": [],
        "shell": "base.sh",
    },
}

def load_cfg():
    if CFG.exists():
        return json.loads(CFG.read_text())
    return {"profiles": []}

def save_cfg(cfg):
    CFG.write_text(json.dumps(cfg, indent=2))

def cmd_list(args):
    cfg = load_cfg()
    active = cfg.get("profiles", [])
    
    print(f"\n{BOLD}DeckDroid — Available Profiles{RESET}\n")
    for name, info in PROFILES.items():
        status = f"{GREEN}(active){RESET}" if name in active else ""
        print(f"  {CYAN}{name}{RESET} {status}")
        print(f"    {info['desc']}")
        if info['pkgs']:
            print(f"    Packages: {', '.join(info['pkgs'])}")
        print()

def cmd_set(args):
    if not args:
        print(f"Usage: ddeckprof set <profile>")
        print(f"Available: {', '.join(PROFILES.keys())}")
        return
    
    name = args[0]
    if name not in PROFILES:
        print(f"{RED}Unknown profile: {name}{RESET}")
        print(f"Available: {', '.join(PROFILES.keys())}")
        return
    
    cfg = load_cfg()
    if name not in cfg.get("profiles", []):
        cfg.setdefault("profiles", []).append(name)
        save_cfg(cfg)
    
    # Install packages
    info = PROFILES[name]
    if info['pkgs']:
        print(f"\n{BOLD}Installing packages for {name}...{RESET}\n")
        for pkg in info['pkgs']:
            print(f"  {CYAN}Installing {pkg}...{RESET}")
            try:
                subprocess.run(["pkg", "install", "-y", pkg], timeout=60)
            except Exception as e:
                print(f"  {YELLOW}Failed: {pkg} ({e}){RESET}")
    
    # Run profile shell script if exists
    shell_script = PROFILES_DIR / info['shell']
    if shell_script.exists():
        print(f"\n{BOLD}Running {name} profile script...{RESET}")
        try:
            subprocess.run(["bash", str(shell_script)])
        except Exception as e:
            print(f"{YELLOW}Error running script: {e}{RESET}")
    
    print(f"\n{GREEN}✓ Profile '{name}' activated!{RESET}")
    print(f"  Run: ddeckprof status")

def cmd_unset(args):
    if not args:
        print(f"Usage: ddeckprof unset <profile>")
        return
    
    name = args[0]
    cfg = load_cfg()
    if name in cfg.get("profiles", []):
        cfg["profiles"].remove(name)
        save_cfg(cfg)
        print(f"{YELLOW}✓ Profile '{name}' deactivated.{RESET}")
    else:
        print(f"{RED}Profile '{name}' is not active.{RESET}")

def cmd_status(args):
    cfg = load_cfg()
    active = cfg.get("profiles", [])
    
    print(f"\n{BOLD}DeckDroid — Profile Status{RESET}\n")
    if not active:
        print(f"  {YELLOW}No active profiles.{RESET}")
        print(f"  Run: ddeckprof set <profile>")
    else:
        print(f"  {GREEN}Active profiles:{RESET}")
        for name in active:
            info = PROFILES.get(name, {})
            print(f"    {CYAN}{name}{RESET} — {info.get('desc', 'N/A')}")
    print()

def cmd_install_all(args):
    print(f"\n{BOLD}Installing all profiles...{RESET}\n")
    for name in PROFILES:
        if name != "base":
            cmd_set([name])
    print(f"\n{GREEN}✓ All profiles installed!{RESET}")

CMDS = {
    "list": cmd_list,
    "set": cmd_set,
    "unset": cmd_unset,
    "status": cmd_status,
    "install-all": cmd_install_all,
}

if __name__ == "__main__":
    args = sys.argv[1:]
    if not args or args[0] not in CMDS:
        print(f"{BOLD}ddeckprof — Profile Manager{RESET}")
        print(f"\nUsage: ddeckprof <command> [args]")
        print(f"\nCommands:")
        print(f"  {CYAN}list{RESET}         List all profiles")
        print(f"  {CYAN}set{RESET} <name>    Activate profile")
        print(f"  {CYAN}unset{RESET} <name>  Deactivate profile")
        print(f"  {CYAN}status{RESET}        Show active profiles")
        print(f"  {CYAN}install-all{RESET}  Install all profiles")
        print(f"\nProfiles: {', '.join(PROFILES.keys())}")
        sys.exit(1)
    CMDS[args[0]](args[1:])
