#!/data/data/com.termux/files/usr/bin/bash
# decklog вЂ” Log viewer for DeckDroid
# Usage: decklog [view|tools|errors|clear] [lines]

DDROID_HOME="${DDROID_HOME:-$HOME/.deckdroid}"
LOG_DIR="$DDROID_HOME/logs"
TOOLS_LOG="$LOG_DIR/tools.log"

R='\033[0;31m'; G='\033[0;32m'; Y='\033[1;33m'; C='\033[0;36m'; N='\033[0m'; B='\033[1m'; DIM='\033[2m'

cmd_view() {
  LOG_FILE="${1:-$LOG_DIR/deckdroid.log}"
  LINES="${2:-50}"
  
  if [ ! -f "$LOG_FILE" ]; then
    echo -e "${Y}No logs found.${N}"
    return 1
  fi
  
  echo -e "${B}${C}в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—${N}"
  echo -e "${B}${C}в•‘    decklog вЂ” View Logs              в•‘${N}"
  echo -e "${B}${C}в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ${N}\n"
  
  tail -n "$LINES" "$LOG_FILE" | while IFS= read -r line; do
    # Color JSON logs
    if echo "$line" | grep -q '"level"'; then
      echo -e "${DIM}$line${N}"
    elif echo "$line" | grep -q '"ERROR"'; then
      echo -e "${R}$line${N}"
    elif echo "$line" | grep -q '"WARN"'; then
      echo -e "${Y}$line${N}"
    else
      echo -e "${G}$line${N}"
    fi
  done
}

cmd_tools() {
  if [ ! -f "$TOOLS_LOG" ]; then
    echo -e "${Y}No tools.log found.${N}"
    return 1
  fi
  
  echo -e "${B}${C}в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—${N}"
  echo -e "${B}${C}в•‘    decklog вЂ” Tools Log              в•‘${N}"
  echo -e "${B}${C}в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ${N}\n"
  
  tail -20 "$TOOLS_LOG" | while IFS= read -r line; do
    echo -e "${DIM}$line${N}"
  done
}

cmd_errors() {
  echo -e "${B}${C}в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—${N}"
  echo -e "${B}${C}в•‘    decklog вЂ” Errors Only            в•‘${N}"
  echo -e "${B}${C}в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ${N}\n"
  
  if [ -f "$LOG_DIR/deckdroid.log" ]; then
    grep -i "error\|fail\|critical" "$LOG_DIR/deckdroid.log" | tail -20 | while IFS= read -r line; do
      echo -e "${R}$line${N}"
    done
  fi
  
  if [ -f "$TOOLS_LOG" ]; then
    echo -e "\n${B}Tools Errors:${N}"
    grep -i "error\|fail" "$TOOLS_LOG" | tail -10
  fi
}

cmd_clear() {
  echo -e "${Y}Clearing logs...${N}"
  rm -f "$LOG_DIR"/*.log 2>/dev/null
  echo -e "${G}вњ“ Logs cleared${N}"
}

# Main
case "${1:-view}" in
  view)   cmd_view "$2" "$3" ;;
  tools)  cmd_tools ;;
  errors) cmd_errors ;;
  clear)  cmd_clear ;;
  *)
    echo -e "${B}decklog вЂ” Log Viewer${N}"
    echo -e "Usage: decklog <command> [args...]\n"
    echo -e "${B}Commands:${N}"
    echo -e "  ${C}view${N}    [file] [lines]  View log file (default: dekcdroid.log)"
    echo -e "  ${C}tools${N}                  View tools.log"
    echo -e "  ${C}errors${N}                 Show only errors"
    echo -e "  ${C}clear${N}                  Clear all logs"
    ;;
esac
