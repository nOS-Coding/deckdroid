#!/data/data/com.termux/files/usr/bin/bash
# deckwifi — WiFi scanner for DeckDroid
# Usage: deckwifi [--json] [--log]

LOG_DIR="$HOME/.deckdroid/logs"
JSON_OUT=false
DO_LOG=false

for arg in "$@"; do
  case $arg in
    --json) JSON_OUT=true ;;
    --log)  DO_LOG=true ;;
  esac
done

TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

# Scan WiFi (with timeout to prevent hang)
WIFI_OUT=$(timeout 10 termux-wifi-scaninfo 2>/dev/null || echo "")
if [ -z "$WIFI_OUT" ]; then
  WIFI_JSON="[]"
  WIFI_TEXT="No WiFi networks found (or termux-api not installed)"
else
  WIFI_JSON="$WIFI_OUT"
  WIFI_TEXT=$(echo "$WIFI_OUT" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    for net in d:
        ssid = net.get('ssid', 'Hidden')
        bssid = net.get('bssid', 'N/A')
        freq = net.get('frequency_mhz', 0)
        signal = net.get('signal_strength', -100)
        # Simple signal bars
        if signal > -50: bars = '▓▓▓'
        elif signal > -70: bars = '▓▓'
        elif signal > -85: bars = '▓'
        else: bars = '░'
        security = net.get('security', 'Open')
        print(f'  {ssid:<20} {bars} {signal}dBm  {security}')
except: pass
" 2>/dev/null)
fi

if $JSON_OUT; then
  echo "$WIFI_JSON"
else
  R='\033[0;31m'; G='\033[0;32m'; Y='\033[0;33m'; C='\033[0;36m'; N='\033[0m'; B='\033[1m'
  echo -e "${B}${C}╔═════════════════════════════════════════╗${N}"
  echo -e "${B}${C}║       deckwifi  v1.1              ║${N}"
  echo -e "${B}${C}╚═════════════════════════════════════════╝${N}"
  if [ -z "$WIFI_OUT" ]; then
    echo -e "  ${Y}No WiFi data available.${N}"
    echo -e "  ${Y}Install termux-api: pkg install termux-api${N}"
  else
    echo "$WIFI_TEXT"
  fi
  echo -e "  ${B}Time      :${N} $TIMESTAMP"
fi

if $DO_LOG; then
  mkdir -p "$LOG_DIR"
  echo "{\"ts\":\"$TIMESTAMP\",\"tool\":\"deckwifi\",\"networks\":$(echo "$WIFI_JSON" | wc -l)}" >> "$LOG_DIR/tools.log"
fi
