#!/usr/bin/env python3
"""deckping — Multi-layer connectivity test"""
import subprocess, sys, time, socket

JSON_OUT = "--json" in sys.argv
GREEN = "\033[0;32m"; RED = "\033[0;31m"; YELLOW = "\033[1;33m"; RESET = "\033[0m"; BOLD = "\033[1m"

TARGETS = [
    ("Gateway",  "192.168.1.1"),
    ("DNS",      "8.8.8.8"),
    ("Internet", "1.1.1.1"),
    ("IPv6",     "2606:4700:4700::1111"),
]

def ping(host, count=3):
    try:
        start = time.time()
        r = subprocess.run(
            ["ping", "-c", str(count), "-W", "2", host],
            capture_output=True, text=True, timeout=10
        )
        elapsed = (time.time() - start) * 1000
        ok = r.returncode == 0
        # Extract avg latency from ping output
        latency = None
        for line in r.stdout.splitlines():
            if "avg" in line or "rtt" in line:
                try:
                    latency = float(line.split("/")[4])
                except Exception:
                    pass
        return ok, latency or elapsed
    except Exception:
        return False, None

results = {}
if not JSON_OUT:
    print(f"\n{BOLD}deckping — Connectivity Test{RESET}")

for label, host in TARGETS:
    ok, latency = ping(host)
    results[label] = {"host": host, "ok": ok, "latency_ms": latency}
    if not JSON_OUT:
        status = f"{GREEN}✓ {latency:.1f}ms{RESET}" if ok else f"{RED}✗ unreachable{RESET}"
        print(f"  {label:<12} {host:<20} {status}")

# DNS resolution test
try:
    socket.gethostbyname("example.com")
    dns_ok = True
except Exception:
    dns_ok = False
results["DNS_resolve"] = {"ok": dns_ok}
if not JSON_OUT:
    print(f"  {'DNS resolve':<12} {'example.com':<20} {GREEN+'✓'+RESET if dns_ok else RED+'✗'+RESET}")
    print()

if JSON_OUT:
    import json; print(json.dumps(results, indent=2))
