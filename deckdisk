#!/data/data/com.termux/files/usr/bin/bash
# deckdisk — Disk management for DeckDroid
# Usage: deckdisk [list|mount|unmount|format] [args...]

DDROID_HOME="${DDROID_HOME:-$HOME/.deckdroid}"
LOG_DIR="$DDROID_HOME/logs"

R='\033[0;31m'; G='\033[0;32m'; Y='\033[1;33m'; C='\033[0;36m'; N='\033[0m'; B='\033[1m'; DIM='\033[2m'

cmd_list() {
  echo -e "${B}${C}╔════════════════════════════════════╗${N}"
  echo -e "${B}${C}║      deckdisk  v1.1 — Disk List     ║${N}"
  echo -e "${B}${C}╚════════════════════════════════════╝${N}\n"
  
  # List all mounted filesystems
  echo -e "${B}Mounted Filesystems:${N}"
  df -h 2>/dev/null | while read line; do
    echo -e "  $line"
  done
  
  echo -e "\n${B}Block Devices:${N}"
  if command -v lsblk &>/dev/null; then
    lsblk -o NAME,SIZE,TYPE,MOUNTPOINT 2>/dev/null | while read line; do
      echo -e "  $line"
    done
  else
    cat /proc/partitions 2>/dev/null | while read line; do
      echo -e "  $line"
    done
  fi
  
  echo -e "\n${DIM}Time: $(date '+%Y-%m-%d %H:%M:%S')${N}"
}

cmd_mount() {
  if [ -z "${1:-}" ]; then
    echo -e "${R}Usage: deckdisk mount <device> [mount_point>${N}"
    return 1
  fi
  
  DEVICE="$1"
  MOUNT_POINT="${2:-/mnt}"
  
  mkdir -p "$MOUNT_POINT" 2>/dev/null
  
  echo -e "${Y}Mounting $DEVICE to $MOUNT_POINT...${N}"
  if mount "$DEVICE" "$MOUNT_POINT" 2>/dev/null; then
    echo -e "${G}✓ Mounted $DEVICE to $MOUNT_POINT${N}"
  else
    echo -e "${R}✗ Mount failed${N}"
    return 1
  fi
}

cmd_unmount() {
  if [ -z "${1:-}" ]; then
    echo -e "${R}Usage: deckdisk unmount <mount_point|device>${N}"
    return 1
  fi
  
  TARGET="$1"
  echo -e "${Y}Unmounting $TARGET...${N}"
  if umount "$TARGET" 2>/dev/null; then
    echo -e "${G}✓ Unmounted $TARGET${N}"
  else
    echo -e "${R}✗ Unmount failed${N}"
    return 1
  fi
}

cmd_format() {
  if [ -z "${1:-}" ]; then
    echo -e "${R}Usage: deckdisk format <device> [fstype>${N}"
    echo -e "${Y}WARNING: This will ERASE all data on $1!${N}"
    return 1
  fi
  
  DEVICE="$1"
  FSTYPE="${2:-ext4}"
  
  echo -e "${R}WARNING: This will ERASE all data on $DEVICE!${N}"
  read -r -p "Type 'YES' to continue: " confirm
  
  if [ "$confirm" = "YES" ]; then
    echo -e "${Y}Formatting $DEVICE as $FSTYPE...${N}"
    case "$FSTYPE" in
      ext4)  mkfs.ext4 "$DEVICE" 2>/dev/null || echo -e "${R}✗ Format failed${N}" ;;
      fat|vfat)  mkfs.vfat "$DEVICE" 2>/dev/null || echo -e "${R}✗ Format failed${N}" ;;
      ntfs)  mkfs.ntfs "$DEVICE" 2>/dev/null || echo -e "${R}✗ Format failed${N}" ;;
      *)    echo -e "${R}Unknown filesystem: $FSTYPE${N}"; return 1 ;;
    esac
    echo -e "${G}✓ Formatted $DEVICE as $FSTYPE${N}"
  else
    echo -e "${Y}Cancelled.${N}"
  fi
}

# Main
case "${1:-list}" in
  list)   cmd_list ;;
  mount)  cmd_mount "$2" "$3" ;;
  unmount|umount) cmd_unmount "$2" ;;
  format) cmd_format "$2" "$3" ;;
  *)
    echo -e "${B}${C}deckdisk — Disk Management${N}"
    echo -e "Usage: deckdisk <command> [args...]\n"
    echo -e "${B}Commands:${N}"
    echo -e "  ${C}list${N}         List all disks and mounts"
    echo -e "  ${C}mount${N} <dev> [pt]  Mount a device"
    echo -e "  ${C}unmount${N} <pt|dev>   Unmount a device"
    echo -e "  ${C}format${N} <dev> [fs]  Format device (DANGEROUS)"
    ;;
esac
