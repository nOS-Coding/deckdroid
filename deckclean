#!/data/data/com.termux/files/usr/bin/bash
# deckclean — Storage cleanup for DeckDroid
# Usage: deckclean [check|clean] [--dry-run]

DDROID_HOME="${DDROID_HOME:-$HOME/.deckdroid}"
DRY_RUN=false

for arg in "$@"; do
  case $arg in
    check)   ;;
    clean)   ;;
    --dry-run) DRY_RUN=true ;;
  esac
done

R='\033[0;31m'; G='\033[0;32m'; Y='\033[1;33m'; C='\033[0;36m'; N='\033[0m'; B='\033[1m'

echo -e "${B}${C}╔════════════════════════════════════════════╗${N}"
echo -e "${B}${C}║      deckclean  v1.1           ║${N}"
echo -e "${B}${C}╚════════════════════════════════════════════╝${N}\n"

# Check disk usage
echo -e "${B}Current Storage:${N}"
df -h "$HOME" 2>/dev/null | while read line; do
  echo -e "  $line"
done

echo ""

# Find cache dirs
CACHE_DIRS=("$HOME/.cache" "$DDROID_HOME/.cache" "/data/data/com.termux/cache")
TOTAL_SAVED=0

echo -e "${B}Cache Directories:${N}"
for dir in "${CACHE_DIRS[@]}"; do
  if [ -d "$dir" ]; then
    SIZE=$(du -sh "$dir" 2>/dev/null | cut -f1)
    echo -e "  ${C}$dir${N} — $SIZE"
    TOTAL_SAVED=$((TOTAL_SAVED + $(du -s "$dir" 2>/dev/null | cut -f1)))
  fi
done

echo -e "\n${B}Package Cache:${N}"
if [ -d "$PREFIX/cache/apt" ]; then
  APT_SIZE=$(du -sh "$PREFIX/cache/apt" 2>/dev/null | cut -f1)
  echo -e "  ${C}apt cache${N} — $APT_SIZE"
fi

# Clean function
if [ "${1:-}" = "clean" ]; then
  if $DRY_RUN; then
    echo -e "\n${Y}[DRY RUN] Would clean:${N}"
  else
    echo -e "\n${Y}Cleaning...${N}"
  fi
  
  # Clean apt cache
  if ! $DRY_RUN; then
    apt-get clean 2>/dev/null || true
    echo -e "${G}✓ APT cache cleared${N}"
  fi
  
  # Clean temp files
  find "$DDROID_HOME" -name "*.tmp" -delete 2>/dev/null || true
  find "$DDROID_HOME" -name "*.log.bak" -delete 2>/dev/null || true
  
  # Clean trash
  TRASH_DIR="$DDROID_HOME/notes/.trash"
  if [ -d "$TRASH_DIR" ] && ! $DRY_RUN; then
    rm -rf "$TRASH_DIR"/*
    echo -e "${G}✓ Trash emptied${N}"
  fi
  
  echo -e "\n${G}✓ Cleanup complete${N}"
else
  echo -e "\n${Y}Run: deckclean clean${N}"
fi

echo -e "${B}Time:${N} $(date '+%Y-%m-%d %H:%M:%S')"
