#!/usr/bin/env python3
"""deckdroid-sync — Git-backed multi-device config sync for DeckDroid"""
import sys
import json
import pathlib
import subprocess
import os

HOME = pathlib.Path.home()
DDROID = HOME / ".deckdroid"
CFG = DDROID / "config.json"

GREEN = "\033[0;32m"
YELLOW = "\033[1;33m"
CYAN = "\033[0;36m"
RESET = "\033[0m"
BOLD = "\033[1m"
RED = "\033[0;31m"

def run_cmd(*args, capture=True):
    result = subprocess.run(args, capture_output=capture, text=True, timeout=30)
    if capture:
        return result.stdout.strip()
    return result.returncode == 0

def cmd_status(args):
    """Check sync status."""
    print(f"\n{BOLD}DeckDroid Sync — Status{RESET}\n")
    
    if not (DDROID / ".git").exists():
        print(f"  {YELLOW}✗ Not initialized{RESET}")
        print(f"  Run: deckdroid-sync init <repo_url>")
        return
    
    # Check remote
    remote = run_cmd("git", "-C", str(DDROID), "remote", "-v")
    print(f"  Remote:  {remote.splitlines()[0] if remote else 'None'}")
    
    # Check status
    status = run_cmd("git", "-C", str(DDROID), "status", "--porcelain")
    if status:
        print(f"  {YELLOW}Status: Changes pending{RESET}")
        print(run_cmd("git", "-C", str(DDROID), "status", "--short"))
    else:
        print(f"  {GREEN}✓ Clean{RESET}")
    
    # Last sync
    last_commit = run_cmd("git", "-C", str(DDROID), "log", "-1", "--format=%ar")
    print(f"  Last:   {last_commit if last_commit else 'Never'}")

def cmd_init(args):
    """Initialize sync with a git repo."""
    if not args:
        print(f"Usage: deckdroid-sync init <git_repo_url>")
        sys.exit(1)
    
    repo_url = args[0]
    print(f"\n{BOLD}Initializing sync...{RESET}\n")
    
    if (DDROID / ".git").exists():
        print(f"  {YELLOW}Already initialized{RESET}")
        return
    
    # Init git repo
    run_cmd("git", "-C", str(DDROID), "init", capture=False)
    
    # Add remote
    run_cmd("git", "-C", str(DDROID), "remote", "add", "origin", repo_url, capture=False)
    
    # Initial commit if needed
    run_cmd("git", "-C", str(DDROID), "add", ".", capture=False)
    run_cmd("git", "-C", str(DDROID), "commit", "-m", "Initial DeckDroid config", capture=False)
    
    print(f"{GREEN}✓ Sync initialized{RESET}")
    print(f"  Push: deckdroid-sync push")

def cmd_push(args):
    """Push config to remote."""
    print(f"\n{BOLD}Pushing config...{RESET}\n")
    
    run_cmd("git", "-C", str(DDROID), "add", ".", capture=False)
    run_cmd("git", "-C", str(DDROID), "commit", "-m", "Update DeckDroid config", capture=False)
    run_cmd("git", "-C", str(DDROID), "push", "origin", "main", capture=False)
    
    print(f"{GREEN}✓ Pushed to remote{RESET}")

def cmd_pull(args):
    """Pull config from remote."""
    print(f"\n{BOLD}Pulling config...{RESET}\n")
    
    run_cmd("git", "-C", str(DDROID), "pull", "origin", "main", capture=False)
    
    print(f"{GREEN}✓ Pulled from remote{RESET}")
    print(f"  Restart shell: source ~/.zshrc")

CMDS = {
    "status": cmd_status,
    "init": cmd_init,
    "push": cmd_push,
    "pull": cmd_pull,
}

if __name__ == "__main__":
    args = sys.argv[1:]
    if not args or args[0] not in CMDS:
        print(f"{BOLD}deckdroid-sync — Git-backed Config Sync{RESET}")
        print(f"Usage: deckdroid-sync <command> [args...]\n")
        print("Commands:")
        print(f"  {CYAN}status{RESET}    Show sync status")
        print(f"  {CYAN}init{RESET}   <repo_url>  Initialize sync with git repo")
        print(f"  {CYAN}push{RESET}    Push config to remote")
        print(f"  {CYAN}pull{RESET}    Pull config from remote")
        sys.exit(1)
    
    CMDS[args[0]](args[1:])
