#!/usr/bin/env python3
"""decklocate — GPS + cell tower triangulation for DeckDroid"""
import sys
import json
import subprocess
import pathlib

DDROID = pathlib.Path.home() / ".deckdroid"
CFG = DDROID / "config.json"
GREEN = "\033[0;32m"
YELLOW = "\033[1;33m"
CYAN = "\033[0;36m"
RESET = "\033[0m"
BOLD = "\033[1m"
RED = "\033[0;31m"

def load_cfg():
    try:
        return json.loads(CFG.read_text())
    except Exception:
        return {}

def get_location_gps():
    try:
        result = subprocess.run(
            ["timeout", "10", "termux-location", "-p", "gps"],
            capture_output=True, text=True, timeout=15
        )
        if result.returncode == 0:
            return json.loads(result.stdout)
    except Exception:
        pass
    return None

def get_location_network():
    try:
        result = subprocess.run(
            ["timeout", "10", "termux-location", "-p", "network"],
            capture_output=True, text=True, timeout=15
        )
        if result.returncode == 0:
            return json.loads(result.stdout)
    except Exception:
        pass
    return None

def cmd_get(args):
    print(f"\n{BOLD}decklocate — Location Services{RESET}\n")
    
    print(f"{BOLD}GPS Location:{RESET}")
    gps = get_location_gps()
    if gps:
        print(f"  Latitude:  {CYAN}{gps.get('latitude', 'N/A')}{RESET}")
        print(f"  Longitude: {CYAN}{gps.get('longitude', 'N/A')}{RESET}")
        print(f"  Accuracy:  {gps.get('accuracy', 'N/A')}m")
        print(f"  Altitude:  {gps.get('altitude', 'N/A')}m")
    else:
        print(f"  {YELLOW}GPS unavailable (check permissions){RESET}")
    
    print(f"\n{BOLD}Network Location:{RESET}")
    net = get_location_network()
    if net:
        print(f"  Latitude:  {CYAN}{net.get('latitude', 'N/A')}{RESET}")
        print(f"  Longitude: {CYAN}{net.get('longitude', 'N/A')}{RESET}")
        print(f"  Accuracy:  {net.get('accuracy', 'N/A')}m")
    else:
        print(f"  {YELLOW}Network location unavailable{RESET}")
    print()

def cmd_track(args):
    if not args:
        print("Usage: decklocate track <seconds>")
        print("Example: decklocate track 10")
        return
    
    try:
        seconds = int(args[0])
    except ValueError:
        print(f"{RED}Invalid time: {args[0]}{RESET}")
        return
    
    print(f"\n{BOLD}Tracking location for {seconds} seconds...{RESET}\n")
    print(f"Press Ctrl+C to stop\n")
    
    try:
        for i in range(seconds):
            gps = get_location_gps()
            if gps:
                print(f"\r  {CYAN}{gps['latitude']:.6f}, {gps['longitude']:.6f}{RESET}  (acc: {gps.get('accuracy', 'N/A')}m)", end="")
            import time
            time.sleep(1)
        print()
    except KeyboardInterrupt:
        print(f"\n\n{YELLOW}Tracking stopped.{RESET}")
    print()

CMDS = {"get": cmd_get, "track": cmd_track}

if __name__ == "__main__":
    args = sys.argv[1:]
    if not args or args[0] not in CMDS:
        print(f"{BOLD}decklocate — Location Services{RESET}")
        print(f"\nUsage: decklocate <command>")
        print(f"\nCommands:")
        print(f"  {CYAN}get{RESET}       Get current location (GPS + Network)")
        print(f"  {CYAN}track{RESET} <sec>  Track location for N seconds")
        sys.exit(1)
    CMDS[args[0]](args[1:])
